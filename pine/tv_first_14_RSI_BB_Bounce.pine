//@version=5
// RSI + BB Bounce — buy oversold dips in uptrend
// Test on: ADAUSDT, ETHUSDT, SOLUSDT — 4h
strategy("RSI BB Bounce", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

rsi = ta.rsi(close, 14)
bb_basis = ta.sma(close, 20)
bb_lower = bb_basis - ta.stdev(close, 20) * 2
bb_upper = bb_basis + ta.stdev(close, 20) * 2
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)

long_entry = rsi < 35 and rsi > rsi[1] and close < bb_lower and close > ema50 and adx > 15 and atr14 < atr_ma * 2
short_entry = rsi > 65 and rsi < rsi[1] and close > bb_upper and close < ema50 and adx > 15 and atr14 < atr_ma * 2

var int trades_today = 0
var int cooldown = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 4
can_trade = trades_today < 3 and cooldown == 0

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * 0.97, limit=close * 1.04)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * 1.03, limit=close * 0.96)
if rsi > 65 and strategy.position_size > 0
    strategy.close("Long")
if rsi < 35 and strategy.position_size < 0
    strategy.close("Short")

plot(bb_lower, "BB Low", color.blue)
plot(bb_upper, "BB Up", color.blue)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
