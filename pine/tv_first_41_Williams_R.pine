//@version=5
// WILLIAMS %R TREND — Overbought/oversold with trend confirmation
// %R crosses from oversold (-80) = trend starting, very responsive indicator
// Larry Williams won the trading championship with 11,376% return in 1987
// Test on: ETHUSDT, BTCUSDT, DOTUSDT, LDOUSDT, SOLUSDT, SUIUSDT — 4h
strategy("Williams %R", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
wr_len = input.int(14, "Williams %R Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// ── WILLIAMS %R (manual calculation) ──
hh = ta.highest(high, wr_len)
ll = ta.lowest(low, wr_len)
wr = (hh - close) / (hh - ll) * -100
wr_cross_up = ta.crossover(wr, -80)   // leaving oversold
wr_cross_down = ta.crossunder(wr, -20) // leaving overbought

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// Tiered
long_strong = wr_cross_up and close > ema50 and adx > 25 and vol_confirm
long_medium = wr_cross_up and close > ema50 and adx > 18
short_strong = wr_cross_down and close < ema50 and adx > 25 and vol_confirm
short_medium = wr_cross_down and close < ema50 and adx > 18

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = ta.crossunder(wr, -20) or (wr > -10 and wr[1] <= -10)
short_exit = ta.crossover(wr, -80) or (wr < -90 and wr[1] >= -90)

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct), limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct), limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="WR")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="WR")
