//@version=5
strategy("tv_12_ADA_PSAR_EMA_Vol", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// TIER_2_DEPLOY: PF=1.70 WR=51.6% ROI=41%/yr on ADA 4h
// Only 4 signals ALL agree — simpler, fewer indicators
sl_pct = input.float(1.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(9.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.7, "Trailing Stop %", step=0.1) / 100

// 1. PSAR Bull
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 2. EMA Cross
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// 3. Volume Spike (2x + bullish)
vol_ma = ta.sma(volume, 20)
sig_vol = (volume > vol_ma * 2.0 and close > close[1]) ? 1 : 0

// 4. OBV Rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

// ALL 4 must agree
total_signals = sig_psar + sig_ema + sig_vol + sig_obv
long_entry = total_signals >= 4
exit_signal = total_signals < 2

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"tv_12_ADA_PSAR_EMA_Vol","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"tv_12_ADA_PSAR_EMA_Vol","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"tv_12_ADA_PSAR_EMA_Vol","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 4 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
