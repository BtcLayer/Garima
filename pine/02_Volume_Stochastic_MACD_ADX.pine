//@version=5
strategy("02_Volume_Stochastic_MACD_ADX", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// === INPUTS ===
sl_pct = input.float(2.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(12.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(2.0, "Trailing Stop %", step=0.1) / 100
min_agreement = input.int(4, "Min Signals Required (Long)", minval=1, maxval=6)
min_agreement_short = input.int(2, "Min Signals Required (Short)", minval=1, maxval=4)

// === INDICATORS (match Python exactly) ===
// 1. Volume_Spike: volume > 1.5x avg AND bullish (momentary)
vol_ma = ta.sma(volume, 20)
sig_volume = (volume > vol_ma * 1.5 and close > close[1]) ? 1 : 0

// 2. Stochastic: K < 20 AND K rising (momentary)
stoch_k = ta.stoch(close, high, low, 14)
sig_stoch = (stoch_k < 20 and stoch_k > stoch_k[1]) ? 1 : 0

// 3. MACD_Cross: MACD crosses above signal (momentary)
// Python: MACD = EMA21 - EMA50, signal = EMA9(MACD)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
macd_line = ema21 - ema50
signal_line = ta.ema(macd_line, 9)
sig_macd = (macd_line > signal_line and macd_line[1] <= signal_line[1]) ? 1 : 0

// 4. ADX_Trend: ADX > 25 (persistent)
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// 5. Trend_MA50: close > EMA50 (persistent)
sig_trend = close > ema50 ? 1 : 0

// 6. Supertrend: close > supertrend (persistent)
atr_val = ta.atr(14)
st_line = (high + low) / 2 - 3 * atr_val
sig_supertrend = close > st_line ? 1 : 0

// === LONG SIGNAL AGREEMENT ===
total_signals = sig_volume + sig_stoch + sig_macd + sig_adx + sig_trend + sig_supertrend
long_entry = total_signals >= min_agreement
exit_signal = total_signals < 1

// === SHORT INDICATORS (reversed conditions) ===
// 1. Volume_Spike_Short: volume > 1.5x avg AND bearish candle
sig_volume_short = (volume > vol_ma * 1.5 and close < close[1]) ? 1 : 0

// 2. Stochastic_Short: K > 80 AND K falling (overbought cross down)
sig_stoch_short = (stoch_k > 80 and stoch_k < stoch_k[1]) ? 1 : 0

// 3. MACD_Cross_Short: MACD crosses below signal
sig_macd_short = (macd_line < signal_line and macd_line[1] >= signal_line[1]) ? 1 : 0

// 4. ADX_Trend_Short: ADX > 25 (same — trend strength, direction-agnostic)
sig_adx_short = adx_val > 25 ? 1 : 0

// === SHORT SIGNAL AGREEMENT ===
total_signals_short = sig_volume_short + sig_stoch_short + sig_macd_short + sig_adx_short
short_entry = total_signals_short >= min_agreement_short
exit_signal_short = total_signals_short < 1

// === LONG STRATEGY EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long",
         stop=strategy.position_avg_price * (1 - sl_pct),
         limit=strategy.position_avg_price * (1 + tp_pct),
         trail_points=1,
         trail_offset=trail_ticks,
         alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

// === SHORT STRATEGY EXECUTION ===
if short_entry and strategy.position_size == 0
    strategy.entry("Short", strategy.short, alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size < 0
    trail_ticks_short = math.round(math.abs(strategy.position_avg_price) * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP Short", "Short",
         stop=strategy.position_avg_price * (1 + sl_pct),
         limit=strategy.position_avg_price * (1 - tp_pct),
         trail_points=1,
         trail_offset=trail_ticks_short,
         alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

if exit_signal_short and strategy.position_size < 0
    strategy.close("Short", comment="Short Signal Exit", alert_message='{"strategy":"Volume_Stochastic_MACD_ADX","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(ema50, "EMA50", color=color.purple)
plot(st_line, "Supertrend", color=close > st_line ? color.green : color.red, linewidth=2)
bgcolor(total_signals >= min_agreement ? color.new(color.green, 90) : total_signals_short >= min_agreement_short ? color.new(color.red, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(short_entry and strategy.position_size == 0, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
