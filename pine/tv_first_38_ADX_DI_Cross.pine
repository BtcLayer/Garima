//@version=5
// ADX + DI CROSSOVER — Pure trend strength entry
// DI+ crosses above DI- = bullish trend starting, ADX rising = trend strengthening
// This is how ADX was DESIGNED to be used by Welles Wilder
// Test on: ETHUSDT, BTCUSDT, DOTUSDT, LDOUSDT, SOLUSDT, SUIUSDT — 4h
strategy("ADX DI Cross", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
adx_len = input.int(14, "ADX Length")
adx_thresh = input.int(20, "ADX Threshold")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// ── ADX + DI ──
[diplus, diminus, adx] = ta.dmi(adx_len, adx_len)
di_cross_up = ta.crossover(diplus, diminus)
di_cross_down = ta.crossunder(diplus, diminus)
adx_rising = adx > adx[1] and adx > adx[2]

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// Tiered
long_strong = di_cross_up and adx > adx_thresh and adx_rising and close > ema50 and vol_confirm
long_medium = di_cross_up and adx > adx_thresh and close > ema50
short_strong = di_cross_down and adx > adx_thresh and adx_rising and close < ema50 and vol_confirm
short_medium = di_cross_down and adx > adx_thresh and close < ema50

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = ta.crossunder(diplus, diminus) or adx < 15 or rsi > 80
short_exit = ta.crossover(diplus, diminus) or adx < 15 or rsi < 20

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct), limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct), limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ADX")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="ADX")
