//@version=5
// LEVEL-BASED: Always positioned based on lookback momentum
// close > close[N] → long, close < close[N] → short
// With 5 anti-overtrading rules
// Test on: NEARUSDT, APTUSDT, OPUSDT, LDOUSDT — 4h timeframe
strategy("Lookback Momentum Always-In", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
lookback = input.int(9, "Lookback Length")
adx_thresh = input.int(20, "ADX Threshold")
sl_pct = input.float(1.0, "SL Cap %") / 100
tp_pct = input.float(3.0, "TP Cap %") / 100
max_trades_day = input.int(3, "Max Trades Per Day")
cooldown_losses = input.int(3, "Cooldown After N Losses")
cooldown_bars = input.int(4, "Cooldown Bars")
circuit_breaker = input.float(-3.0, "Daily Circuit Breaker %") / 100

// ── CORE SIGNAL ──
momentum_up = close > close[lookback]
momentum_down = close < close[lookback]

// ── FILTERS ──
// ADX — only trade when trending
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_ok = adx > adx_thresh

// ATR — skip extreme volatility
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// ── ANTI-OVERTRADING RULES ──

// Rule 1: Max trades per day
var int trades_today = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
trades_ok = trades_today < max_trades_day

// Rule 2: Cooldown after consecutive losses
var int consec_losses = 0
var int cooldown_remaining = 0
if cooldown_remaining > 0
    cooldown_remaining -= 1
cooldown_ok = cooldown_remaining == 0

// Track wins/losses
was_long = strategy.position_size[1] > 0 and strategy.position_size <= 0
was_short = strategy.position_size[1] < 0 and strategy.position_size >= 0
trade_closed = was_long or was_short

if trade_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= cooldown_losses
            cooldown_remaining := cooldown_bars
            consec_losses := 0
    else
        consec_losses := 0

// Rule 3: Daily circuit breaker
var float day_start_equity = strategy.equity
if is_new_day
    day_start_equity := strategy.equity
daily_pnl_pct = (strategy.equity - day_start_equity) / day_start_equity
circuit_ok = daily_pnl_pct > circuit_breaker

// Rule 4: Minimum gap between trades (2 bars)
var int bars_since_close = 100
if trade_closed
    bars_since_close := 0
else
    bars_since_close += 1
gap_ok = bars_since_close >= 2

// ── COMBINED SIGNAL ──
all_filters = adx_ok and vol_ok and trades_ok and cooldown_ok and circuit_ok and gap_ok
bull = momentum_up and all_filters
bear = momentum_down and all_filters

// ── EXECUTION ──
if bull and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_Risk", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))

if bear and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_Risk", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))

// Go flat when filters fail
if not adx_ok or not vol_ok or not circuit_ok
    if strategy.position_size > 0
        strategy.close("Long")
    if strategy.position_size < 0
        strategy.close("Short")

// ── VISUALS ──
bgcolor(bull ? color.new(color.green, 90) : bear ? color.new(color.red, 90) : na)
bgcolor(not circuit_ok ? color.new(color.red, 70) : na, title="Circuit Breaker Active")
bgcolor(cooldown_remaining > 0 ? color.new(color.orange, 80) : na, title="Cooldown Active")
plot(close[lookback], "Lookback Price", color.orange, 1, plot.style_stepline)

// Info table
var table info = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "Trades Today", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(trades_today) + "/" + str.tostring(max_trades_day), text_color=trades_ok ? color.green : color.red, text_size=size.small)
    table.cell(info, 0, 1, "Cooldown", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, cooldown_remaining > 0 ? str.tostring(cooldown_remaining) + " bars" : "OFF", text_color=cooldown_ok ? color.green : color.orange, text_size=size.small)
    table.cell(info, 0, 2, "Daily P&L", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(math.round(daily_pnl_pct * 100, 2)) + "%", text_color=circuit_ok ? color.green : color.red, text_size=size.small)
    table.cell(info, 0, 3, "ADX", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(math.round(adx, 1)), text_color=adx_ok ? color.green : color.gray, text_size=size.small)
