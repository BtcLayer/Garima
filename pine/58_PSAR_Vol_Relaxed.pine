//@version=5
strategy("58_PSAR_Vol_Relaxed", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Based on 44 (best: 508%/yr ETH) — relaxed volume filter for MORE trades
// Changed: vol > 1.2x (was 2x), added OBV + Ichimoku for quality
sl_pct = input.float(1.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(6.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.7, "Trailing Stop %", step=0.1) / 100

// 1. PSAR bull
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 2. Volume above average (RELAXED: 1.2x instead of 2x) + bullish
vol_ma = ta.sma(volume, 20)
sig_vol = (volume > vol_ma * 1.2 and close > close[1]) ? 1 : 0

// 3. EMA trend
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// 4. Supertrend
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
sig_super = close > supertrend ? 1 : 0

// 5. Trend MA50
ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

// 6. OBV rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

total_signals = sig_psar + sig_vol + sig_ema + sig_super + sig_trend50 + sig_obv
long_entry = total_signals >= 5
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"PSAR_Vol_Relaxed","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"PSAR_Vol_Relaxed","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"PSAR_Vol_Relaxed","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
