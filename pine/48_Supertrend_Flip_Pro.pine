//@version=5
strategy("48_Supertrend_Flip_Pro", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Supertrend flips bullish + EMA + ADX + PSAR — entry only on flip
sl_pct = input.float(1.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(6.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.6, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. Supertrend flip (was bearish, now bullish)
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
super_bull = close > supertrend
super_flip = super_bull and not super_bull[1]

// 2. EMA Cross
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// 3. ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// 4. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// === Entry on Supertrend flip + all other signals ===
total_signals = (super_bull ? 1 : 0) + sig_ema + sig_adx + sig_psar
long_entry = super_flip and sig_ema == 1 and sig_adx == 1 and sig_psar == 1
exit_signal = total_signals < 2

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Supertrend_Flip_Pro","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Supertrend_Flip_Pro","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Supertrend_Flip_Pro","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(supertrend, "Supertrend", color=super_bull ? color.green : color.red)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 4 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(super_flip, "ST Flip", shape.diamond, location.abovebar, color.lime, size=size.tiny)
