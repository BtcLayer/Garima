//@version=5
// Target: 1%/day + PF>=1.4 + WR>=50%
// FULL combo: EMA(5/30)+PSAR(0.01)+Supertrend(3.5)+Ichimoku(9/22)+ADX>25+OBV+MA50
// 7 signals, need 5 of 7 to enter — TP=6%, SL=1%, TS=0.5%
strategy("tv_09_ETH_Full_TP6", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(6.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// EMA 5/30
ema5 = ta.ema(close, 5)
ema30 = ta.ema(close, 30)
sig_ema = ema5 > ema30 ? 1 : 0

// PSAR (slower af=0.01)
psar = ta.sar(0.01, 0.01, 0.2)
sig_psar = close > psar ? 1 : 0

// Supertrend ATR*3.5
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3.5 * atr14
sig_super = close > supertrend ? 1 : 0

// Ichimoku 9/22
tenkan_period = 9
kijun_period = 22
tenkan = (ta.highest(high, tenkan_period) + ta.lowest(low, tenkan_period)) / 2
kijun = (ta.highest(high, kijun_period) + ta.lowest(low, kijun_period)) / 2
spanA = (tenkan + kijun) / 2
spanB = (ta.highest(high, 44) + ta.lowest(low, 44)) / 2
sig_ichi = (close > spanA and close > spanB and tenkan > kijun) ? 1 : 0

// ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = (adx_val > 25 and diplus > diminus) ? 1 : 0

// OBV Rising
obv = ta.obv
obv_ma = ta.sma(obv, 20)
sig_obv = obv > obv_ma ? 1 : 0

// MA50 Trend
ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

total_signals = sig_ema + sig_psar + sig_super + sig_ichi + sig_adx + sig_obv + sig_trend50
long_entry = total_signals >= 5
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"tv_09_ETH_Full_TP6","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"tv_09_ETH_Full_TP6","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"tv_09_ETH_Full_TP6","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema5, "EMA5", color=color.blue)
plot(ema30, "EMA30", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
plot(tenkan, "Tenkan", color=color.new(color.red, 50))
plot(kijun, "Kijun", color=color.new(color.blue, 50))
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
