//@version=5
// MULTI-DIP + TREND FILTER: Buy when 3+ oversold indicators agree + trend is up
// This combines mean reversion (dip buying) with trend confirmation
// Test on: ETHUSDT, ADAUSDT, BTCUSDT, LINKUSDT — 4h
strategy("Multi Dip Trend Filter", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── TREND FILTER (must be in uptrend to buy dips) ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[st_val, st_dir] = ta.supertrend(3, 14)
trend_up = close > ema50 and ema50 > ema200
trend_down = close < ema50 and ema50 < ema200

// ── DIP INDICATORS (count how many say "oversold") ──
rsi = ta.rsi(close, 14)
stoch_k = ta.stoch(close, high, low, 14)
bb_basis = ta.sma(close, 20)
bb_lower = bb_basis - ta.stdev(close, 20) * 2
bb_upper = bb_basis + ta.stdev(close, 20) * 2
cci_val = ta.cci(close, 20)
mfi_val = ta.mfi(hlc3, 14)
wpr = ta.wpr(14)

// Count oversold signals
dip_count = 0
dip_count += rsi < 35 ? 1 : 0
dip_count += stoch_k < 25 ? 1 : 0
dip_count += close < bb_lower ? 1 : 0
dip_count += cci_val < -80 ? 1 : 0
dip_count += mfi_val < 25 ? 1 : 0
dip_count += wpr < -75 ? 1 : 0

// Count overbought signals (for shorts)
ob_count = 0
ob_count += rsi > 65 ? 1 : 0
ob_count += stoch_k > 75 ? 1 : 0
ob_count += close > bb_upper ? 1 : 0
ob_count += cci_val > 80 ? 1 : 0
ob_count += mfi_val > 75 ? 1 : 0
ob_count += wpr > -25 ? 1 : 0

// Minimum 3 dip signals must agree
min_dips = input.int(3, "Min Dip Signals", minval=2, maxval=6)

// ── ADX + ATR FILTER ──
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity

is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1

was_closed = (strategy.position_size[1] != 0 and strategy.position_size == 0)
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0

daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03 and vol_ok

// ── ENTRY ──
// Buy dip when: trend is UP + 3+ oversold indicators + bouncing (RSI rising)
long_entry = trend_up and dip_count >= min_dips and rsi > rsi[1] and can_trade
// Short when: trend is DOWN + 3+ overbought indicators + falling
short_entry = trend_down and ob_count >= min_dips and rsi < rsi[1] and can_trade

// ── EXIT ──
long_exit = rsi > 65 or close > bb_upper or ta.crossunder(close, ema50)
short_exit = rsi < 35 or close < bb_lower or ta.crossover(close, ema50)

// ── EXECUTION ──
if long_entry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_SL", "Long", stop=close * 0.98, limit=close * 1.04)

if short_entry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_SL", "Short", stop=close * 1.02, limit=close * 0.96)

if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plot(ema200, "EMA200", color.orange, 2)
plotshape(long_entry, "Dip Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry, "OB Sell", shape.triangledown, location.abovebar, color.red, size=size.small)

var table info = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "Dip Count", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(dip_count) + "/6", text_color=dip_count >= min_dips ? color.green : color.gray, text_size=size.small)
    table.cell(info, 0, 1, "OB Count", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(ob_count) + "/6", text_color=ob_count >= min_dips ? color.red : color.gray, text_size=size.small)
    table.cell(info, 0, 2, "Trend", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, trend_up ? "UP" : trend_down ? "DOWN" : "FLAT", text_color=trend_up ? color.green : trend_down ? color.red : color.gray, text_size=size.small)
