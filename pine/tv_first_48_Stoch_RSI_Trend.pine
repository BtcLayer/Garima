//@version=5
// STOCHASTIC RSI + TREND — Stoch RSI is more sensitive than regular RSI
// Stoch RSI crosses from oversold in uptrend = high probability entry
// Popular among crypto day traders
strategy("Stoch RSI Trend", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Stoch RSI Trend","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Stoch RSI Trend","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Stoch RSI Trend","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Stoch RSI Trend","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

rsi_len = input.int(14, "RSI Length")
stoch_len = input.int(14, "Stoch Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

rsi = ta.rsi(close, rsi_len)
stoch_rsi_k = ta.sma(ta.stoch(rsi, rsi, rsi, stoch_len), 3)
stoch_rsi_d = ta.sma(stoch_rsi_k, 3)

cross_up = ta.crossover(stoch_rsi_k, stoch_rsi_d) and stoch_rsi_k < 30
cross_down = ta.crossunder(stoch_rsi_k, stoch_rsi_d) and stoch_rsi_k > 70

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
vol_ok = atr14 < ta.sma(atr14, 100) * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

long_strong = cross_up and close > ema50 and adx > 25 and vol_confirm
long_medium = cross_up and close > ema50 and adx > 18
short_strong = cross_down and close < ema50 and adx > 25 and vol_confirm
short_medium = cross_down and close < ema50 and adx > 18

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

long_exit = ta.crossunder(stoch_rsi_k, stoch_rsi_d) and stoch_rsi_k > 80
short_exit = ta.crossover(stoch_rsi_k, stoch_rsi_d) and stoch_rsi_k < 20

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(ema50, "EMA50", color.blue, 2)
plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
