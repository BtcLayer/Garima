//@version=5
strategy("Reverse SMA 9 Cross", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000)

// --- Input Parameters ---
smaLength = input.int(9, title="SMA Length")
tpPercent = input.float(2.5, title="Take Profit (%)")
slPercent = input.float(1.5, title="Stop Loss (%)")

// --- Indicators ---
smaValue = ta.sma(close, smaLength)

// --- Reverse Logic Definition ---
// Standard: Buy when price crosses UP (Bullish)
// Reverse: Sell when price crosses UP (Mean Reversion/Fade)
priceCrossUp   = ta.crossover(close, smaValue)
priceCrossDown = ta.crossunder(close, smaValue)

// --- Execution ---
// We enter Short on a "Bullish" cross and Long on a "Bearish" cross
if (priceCrossUp)
    strategy.entry("Rev-Short", strategy.short, comment="Fading Upside Cross")

if (priceCrossDown)
    strategy.entry("Rev-Long", strategy.long, comment="Fading Downside Cross")

// --- Visuals ---
plot(smaValue, color=color.orange, title="SMA 9")
plotshape(priceCrossUp, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="Reverse Short Signal")
plotshape(priceCrossDown, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="Reverse Long Signal")

// --- Risk Management ---
// Using tighter stops to counteract the -32% drawdown seen in your original backtest
strategy.exit("X-Long", "Rev-Long", limit=strategy.position_avg_price * (1 + tpPercent/100), stop=strategy.position_avg_price * (1 - slPercent/100))
strategy.exit("X-Short", "Rev-Short", limit=strategy.position_avg_price * (1 - tpPercent/100), stop=strategy.position_avg_price * (1 + slPercent/100))