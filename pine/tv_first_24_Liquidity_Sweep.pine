//@version=5
// LIQUIDITY SWEEP REVERSAL — Prime Algo concept
// Logic: Price sweeps above/below recent high/low (grabs liquidity/stops),
// then REVERSES. This is how institutional algos hunt retail stops.
// Entry: After sweep + reversal candle. Opposite of breakout — we FADE the breakout.
// Test on: ETHUSDT, BTCUSDT, LDOUSDT — 4h
strategy("Liquidity Sweep Reversal", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
lookback = input.int(20, "Swing Lookback")
sweep_wick_pct = input.float(0.3, "Min Wick % of Range", step=0.1)
sl_pct = input.float(2.0, "SL %") / 100
tp_pct = input.float(4.0, "TP %") / 100

// ── SWING HIGHS/LOWS (liquidity levels) ──
swing_high = ta.highest(high, lookback)[1]  // previous high (where stops sit)
swing_low = ta.lowest(low, lookback)[1]     // previous low (where stops sit)

// ── SWEEP DETECTION ──
// Bullish sweep: price dips BELOW swing low (grabs stops) then closes ABOVE it
swept_low = low < swing_low and close > swing_low
// Bearish sweep: price spikes ABOVE swing high (grabs stops) then closes BELOW it
swept_high = high > swing_high and close < swing_high

// ── REVERSAL CANDLE CONFIRMATION ──
body = math.abs(close - open)
total_range = high - low
lower_wick = math.min(close, open) - low
upper_wick = high - math.max(close, open)

// Bullish reversal: long lower wick after sweep low (buyers absorbed selling)
bull_reversal = swept_low and lower_wick > total_range * sweep_wick_pct and close > open
// Bearish reversal: long upper wick after sweep high (sellers absorbed buying)
bear_reversal = swept_high and upper_wick > total_range * sweep_wick_pct and close < open

// ── FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2.5  // slightly more lenient — sweeps happen in volatility
rsi = ta.rsi(close, 14)

// Don't fade strong trends — only sweep in ranging/weak trend markets
adx_not_extreme = adx < 40

// RSI confirmation — oversold for bull sweep, overbought for bear sweep
rsi_bull = rsi < 40
rsi_bear = rsi > 60

long_entry = bull_reversal and vol_ok and adx_not_extreme and rsi_bull
short_entry = bear_reversal and vol_ok and adx_not_extreme and rsi_bear

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))

// Exit on RSI reversal
if rsi > 65 and strategy.position_size > 0
    strategy.close("Long")
if rsi < 35 and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(swing_high, "Swing High", color.red, 1, plot.style_stepline)
plot(swing_low, "Swing Low", color.green, 1, plot.style_stepline)
plotshape(long_entry and can_trade, "Sweep Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="SWEEP")
plotshape(short_entry and can_trade, "Sweep Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="SWEEP")
bgcolor(swept_low ? color.new(color.green, 92) : swept_high ? color.new(color.red, 92) : na)
