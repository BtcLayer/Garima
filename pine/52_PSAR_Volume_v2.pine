//@version=5
strategy("52_PSAR_Volume_v2", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Based on 44_PSAR_Volume_Surge with tighter TP, wider SL + Trend_MA50 filter
// PSAR + Volume 2x + Bullish Candle + EMA Cross + Supertrend + Trend_MA50 — 5 of 6 must agree
sl_pct = input.float(2.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(3.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 2. Volume > 2x average
vol_sma = ta.sma(volume, 20)
sig_vol = volume > vol_sma * 2 ? 1 : 0

// 3. close > close[1] (bullish candle)
sig_bull = close > close[1] ? 1 : 0

// 4. EMA Cross
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// 5. Supertrend
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
sig_super = close > supertrend ? 1 : 0

// 6. Trend MA50 (close above SMA50)
ma50 = ta.sma(close, 50)
sig_ma50 = close > ma50 ? 1 : 0

// === 5 of 6 must agree for entry ===
total_signals = sig_psar + sig_vol + sig_bull + sig_ema + sig_super + sig_ma50
long_entry = total_signals >= 5
exit_signal = total_signals < 3

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"PSAR_Volume_v2","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"PSAR_Volume_v2","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"PSAR_Volume_v2","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(supertrend, "Supertrend", color=color.green)
plot(ma50, "MA50", color=color.purple)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
