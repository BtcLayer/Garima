//@version=5
strategy("tv_11_ADA_TP9", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Target: TIER_2_DEPLOY — Bot PF=1.68 WR=51.4% ROI=40.4%/yr on ADA 4h
// PSAR + Volume>2x + EMA8/21 + Supertrend + MA50 — ALL 5 agree
sl_pct = input.float(1.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(9.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.7, "Trailing Stop %", step=0.1) / 100

psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

vol_ma = ta.sma(volume, 20)
sig_vol = (volume > vol_ma * 2.0 and close > close[1]) ? 1 : 0

ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
sig_super = close > supertrend ? 1 : 0

ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

total_signals = sig_psar + sig_vol + sig_ema + sig_super + sig_trend50
long_entry = total_signals >= 5
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"tv_11_ADA_TP9","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"tv_11_ADA_TP9","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"tv_11_ADA_TP9","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
