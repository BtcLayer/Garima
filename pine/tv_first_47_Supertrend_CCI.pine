//@version=5
// SUPERTREND + CCI — Supertrend for direction, CCI for timing
// Supertrend flip = trend change, CCI > 100 = momentum confirmed
// Two independently strong indicators combined
strategy("Supertrend CCI", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

st_factor = input.float(3.0, "Supertrend Factor")
st_period = input.int(10, "Supertrend Period")
cci_len = input.int(20, "CCI Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

[st_val, st_dir] = ta.supertrend(st_factor, st_period)
st_flip_bull = st_dir == -1 and st_dir[1] == 1
st_flip_bear = st_dir == 1 and st_dir[1] == -1
st_bull = st_dir == -1
st_bear = st_dir == 1

cci = ta.cci(close, cci_len)
cci_strong_bull = cci > 100
cci_strong_bear = cci < -100
cci_cross_up = ta.crossover(cci, 100)
cci_cross_down = ta.crossunder(cci, -100)

ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
vol_ok = atr14 < ta.sma(atr14, 100) * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// Both within 3 bars
st_recent_bull = st_flip_bull or st_flip_bull[1] or st_flip_bull[2]
cci_recent_bull = cci_cross_up or cci_cross_up[1] or cci_cross_up[2]
st_recent_bear = st_flip_bear or st_flip_bear[1] or st_flip_bear[2]
cci_recent_bear = cci_cross_down or cci_cross_down[1] or cci_cross_down[2]

long_strong = st_recent_bull and cci_recent_bull and close > ema50 and adx > 25 and vol_confirm
long_medium = (st_flip_bull and cci > 0 and adx > 20) or (cci_cross_up and st_bull and adx > 20)
short_strong = st_recent_bear and cci_recent_bear and close < ema50 and adx > 25 and vol_confirm
short_medium = (st_flip_bear and cci < 0 and adx > 20) or (cci_cross_down and st_bear and adx > 20)

long_entry = (long_strong or long_medium) and close > ema50
short_entry = (short_strong or short_medium) and close < ema50

long_exit = st_flip_bear or cci < -50
short_exit = st_flip_bull or cci > 50

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(st_val, "ST", color=st_dir==-1?color.green:color.red, linewidth=2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
