//@version=5
// MACD Momentum V2 — MACD zero cross + EMA200 trend + volume + ADX
// MACD_Breakout was the ONLY strategy that showed profit on TV (FIL 1h +28.7%)
// This is an improved version for 4h with anti-overtrading
// Test on: LTCUSDT, ETHUSDT, BTCUSDT, ADAUSDT — 4h
strategy("MACD Momentum V2", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)
ema200 = ta.ema(close, 200)
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// MACD crosses zero (stronger than signal cross)
macd_zero_up = macd_line > 0 and macd_line[1] <= 0 and close > ema200 and adx > 20 and vol_ok
macd_zero_down = macd_line < 0 and macd_line[1] >= 0 and close < ema200 and adx > 20 and vol_ok

// Also enter on strong MACD signal cross with volume
macd_sig_up = ta.crossover(macd_line, signal_line) and hist > 0 and close > ema50 and vol_confirm and adx > 25
macd_sig_down = ta.crossunder(macd_line, signal_line) and hist < 0 and close < ema50 and vol_confirm and adx > 25

long_entry = macd_zero_up or macd_sig_up
short_entry = macd_zero_down or macd_sig_down

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * 0.97, limit=close * 1.06)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * 1.03, limit=close * 0.94)
if ta.crossunder(macd_line, signal_line) and strategy.position_size > 0
    strategy.close("Long")
if ta.crossover(macd_line, signal_line) and strategy.position_size < 0
    strategy.close("Short")

plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
