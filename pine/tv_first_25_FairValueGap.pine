//@version=5
// FAIR VALUE GAP (FVG) — Institutional order flow concept
// FVG = gap between candle 1's high and candle 3's low (bullish)
// or candle 1's low and candle 3's high (bearish)
// Price tends to return to fill FVGs — enter when it does
// Test on: ETHUSDT, BTCUSDT, LDOUSDT — 4h
strategy("Fair Value Gap", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
min_gap_pct = input.float(0.5, "Min FVG Size %", step=0.1) / 100
sl_pct = input.float(2.0, "SL %") / 100
tp_pct = input.float(4.0, "TP %") / 100

// ── FVG DETECTION ──
// Bullish FVG: candle[2] high < candle[0] low (gap up)
bull_fvg_top = low
bull_fvg_bot = high[2]
bull_fvg_exists = bull_fvg_bot < bull_fvg_top and (bull_fvg_top - bull_fvg_bot) / close > min_gap_pct

// Bearish FVG: candle[2] low > candle[0] high (gap down)
bear_fvg_top = low[2]
bear_fvg_bot = high
bear_fvg_exists = bear_fvg_top > bear_fvg_bot and (bear_fvg_top - bear_fvg_bot) / close > min_gap_pct

// ── PRICE RETURNS TO FVG (entry trigger) ──
// Track recent FVGs
var float last_bull_fvg_top = na
var float last_bull_fvg_bot = na
var float last_bear_fvg_top = na
var float last_bear_fvg_bot = na
var int bars_since_bull_fvg = 100
var int bars_since_bear_fvg = 100

if bull_fvg_exists
    last_bull_fvg_top := bull_fvg_top
    last_bull_fvg_bot := bull_fvg_bot
    bars_since_bull_fvg := 0
else
    bars_since_bull_fvg += 1

if bear_fvg_exists
    last_bear_fvg_top := bear_fvg_top
    last_bear_fvg_bot := bear_fvg_bot
    bars_since_bear_fvg := 0
else
    bars_since_bear_fvg += 1

// Price enters bullish FVG zone (pullback into gap = buy)
bull_fill = not na(last_bull_fvg_bot) and low <= last_bull_fvg_top and close > last_bull_fvg_bot and bars_since_bull_fvg > 1 and bars_since_bull_fvg < 15
// Price enters bearish FVG zone (rally into gap = sell)
bear_fill = not na(last_bear_fvg_top) and high >= last_bear_fvg_bot and close < last_bear_fvg_top and bars_since_bear_fvg > 1 and bars_since_bear_fvg < 15

// ── FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
ema50 = ta.ema(close, 50)
trend_up = close > ema50
trend_down = close < ema50
rsi = ta.rsi(close, 14)

// Only fill FVGs in trend direction
long_entry = bull_fill and trend_up and adx > 15 and vol_ok and rsi < 60
short_entry = bear_fill and trend_down and adx > 15 and vol_ok and rsi > 40

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int cooldown = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 4
can_trade = trades_today < 3 and cooldown == 0

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))
    last_bull_fvg_top := na  // reset after entry

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))
    last_bear_fvg_top := na

if rsi > 70 and strategy.position_size > 0
    strategy.close("Long")
if rsi < 30 and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
bgcolor(bull_fvg_exists ? color.new(color.green, 90) : bear_fvg_exists ? color.new(color.red, 90) : na)
plotshape(long_entry and can_trade, "FVG Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="FVG")
plotshape(short_entry and can_trade, "FVG Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="FVG")
