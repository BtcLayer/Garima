//@version=5
// CCI + DONCHIAN FUSION — Combines our #1 and #2 best strategies
// CCI > 100 = strong momentum + Donchian breakout = price at new high
// Both must agree before entry — double confirmation
strategy("CCI Donchian Fusion", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

entry_len = input.int(20, "Donchian Length")
cci_len = input.int(20, "CCI Length")
cci_thresh = input.int(100, "CCI Threshold")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// Donchian
don_upper = ta.highest(high, entry_len)
don_lower = ta.lowest(low, entry_len)
don_break_up = close > don_upper[1]
don_break_down = close < don_lower[1]

// CCI
cci = ta.cci(close, cci_len)
cci_bull = ta.crossover(cci, cci_thresh)
cci_bear = ta.crossunder(cci, -cci_thresh)

// Confirmation
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
vol_ok = atr14 < ta.sma(atr14, 100) * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// FUSION: both signals within 3 bars of each other
don_recent_up = don_break_up or don_break_up[1] or don_break_up[2]
don_recent_down = don_break_down or don_break_down[1] or don_break_down[2]
cci_recent_up = cci_bull or cci_bull[1] or cci_bull[2]
cci_recent_down = cci_bear or cci_bear[1] or cci_bear[2]

long_strong = don_recent_up and cci_recent_up and close > ema50 and adx > 25 and vol_confirm
long_medium = (don_break_up and cci > 0 and adx > 20) or (cci_bull and close > don_upper[1] * 0.99 and adx > 20)
short_strong = don_recent_down and cci_recent_down and close < ema50 and adx > 25 and vol_confirm
short_medium = (don_break_down and cci < 0 and adx > 20) or (cci_bear and close < don_lower[1] * 1.01 and adx > 20)

long_entry = long_strong or (long_medium and close > ema50)
short_entry = short_strong or (short_medium and close < ema50)

long_exit = cci < 0 and close < ta.lowest(low, 10)[1]
short_exit = cci > 0 and close > ta.highest(high, 10)[1]

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(don_upper, "Don Hi", color.green)
plot(don_lower, "Don Lo", color.red)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
