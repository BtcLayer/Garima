//@version=5
// REGIME + MACD COMBO — combines our #1 and #2 TV winners
// Regime Adaptive was best (ETH +8.1%/yr), MACD V2 had best PF (3.76)
// This combines: detect regime + enter on MACD signal + squeeze confirmation
// Test on: BTCUSDT, ETHUSDT — 4h
strategy("Regime MACD Combo", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── Regime Detection (from winner #1) ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
is_bull = ema50 > ema200 and adx > 25
is_bear = ema50 < ema200 and adx > 25
is_sideways = adx < 20

// ── MACD (from winner #2) ──
[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)
macd_cross_up = ta.crossover(macd_line, signal_line)
macd_cross_down = ta.crossunder(macd_line, signal_line)
macd_zero_up = macd_line > 0 and macd_line[1] <= 0
macd_zero_down = macd_line < 0 and macd_line[1] >= 0

// ── Squeeze (from winner #3) ──
bb_upper = ta.sma(close, 20) + ta.stdev(close, 20) * 2
bb_lower = ta.sma(close, 20) - ta.stdev(close, 20) * 2
kc_upper = ta.ema(close, 20) + 1.5 * ta.atr(20)
kc_lower = ta.ema(close, 20) - 1.5 * ta.atr(20)
squeeze_on = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_release = not squeeze_on and squeeze_on[1]

// ── Volume + ATR ──
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// ── BULL REGIME ENTRIES (multiple confirmation) ──
// MACD cross up in bull trend
bull_macd = is_bull and (macd_cross_up or macd_zero_up) and vol_ok
// Squeeze release in bull trend with positive momentum
bull_squeeze = is_bull and squeeze_release and hist > 0 and vol_ok

// ── BEAR REGIME ENTRIES ──
bear_macd = is_bear and (macd_cross_down or macd_zero_down) and vol_ok
bear_squeeze = is_bear and squeeze_release and hist < 0 and vol_ok

// ── SIDEWAYS: Mean reversion (from Regime Adaptive) ──
side_long = is_sideways and rsi < 35 and rsi > rsi[1] and close < bb_lower
side_short = is_sideways and rsi > 65 and rsi < rsi[1] and close > bb_upper

long_entry = bull_macd or bull_squeeze or side_long
short_entry = bear_macd or bear_squeeze or side_short

// ── Anti-overtrading ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── Execution ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * 0.97, limit=close * 1.06)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * 1.03, limit=close * 0.94)

// Exit on MACD reversal
if macd_cross_down and strategy.position_size > 0
    strategy.close("Long")
if macd_cross_up and strategy.position_size < 0
    strategy.close("Short")
// Exit sideways trades quickly
if is_sideways and rsi > 60 and strategy.position_size > 0
    strategy.close("Long")
if is_sideways and rsi < 40 and strategy.position_size < 0
    strategy.close("Short")

// ── Visuals ──
bgcolor(is_bull ? color.new(color.green, 95) : is_bear ? color.new(color.red, 95) : color.new(color.gray, 97))
plot(ema50, "EMA50", color.blue, 2)
plot(ema200, "EMA200", color.orange, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
