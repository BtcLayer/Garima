//@version=5
// ENGULFING + VOLUME — Candlestick pattern + volume confirmation
// Engulfing candle with high volume = strong reversal signal
// From our backtester: Engulfing_Trend on ETH showed 0.062%/day with GDD=19.5%
// This is a cleaner implementation for TV
// Test on: ETHUSDT, BTCUSDT, DOTUSDT — 4h
strategy("Engulfing Volume", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
sl_pct = input.float(2.0, "SL %") / 100
tp_pct = input.float(5.0, "TP %") / 100
vol_mult = input.float(1.5, "Volume Multiplier")

// ── CANDLE PATTERNS ──
body = math.abs(close - open)
body_prev = math.abs(close[1] - open[1])

// Bullish engulfing: current green candle fully covers previous red candle
bull_engulf = close > open and close[1] < open[1] and open <= close[1] and close >= open[1] and body > body_prev

// Bearish engulfing: current red candle fully covers previous green candle
bear_engulf = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and body > body_prev

// ── VOLUME CONFIRMATION ──
vol_sma = ta.sma(volume, 20)
high_vol = volume > vol_sma * vol_mult

// ── TREND FILTER ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// Bull engulfing at support + uptrend
long_entry = bull_engulf and high_vol and close > ema50 and adx > 15 and vol_ok and rsi < 65
// Bear engulfing at resistance + downtrend
short_entry = bear_engulf and high_vol and close < ema50 and adx > 15 and vol_ok and rsi > 35

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int cooldown = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 4
can_trade = trades_today < 3 and cooldown == 0

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))
if rsi > 75 and strategy.position_size > 0
    strategy.close("Long")
if rsi < 25 and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Bull Engulf", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ENG")
plotshape(short_entry and can_trade, "Bear Engulf", shape.triangledown, location.abovebar, color.red, size=size.small, text="ENG")
