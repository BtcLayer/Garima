//@version=5
strategy("10 Aggressive Entry [Webhook]", overlay=true, commission_type=strategy.commission.percent, commission_value=0.1, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// Inputs
ema_fast_len = input.int(9,   title="EMA Fast Length")
ema_slow_len = input.int(21,  title="EMA Slow Length")
rsi_len      = input.int(14,  title="RSI Length")
vol_sma_len  = input.int(20,  title="Volume SMA Length")
vol_mult     = input.float(1.2, title="Volume Multiplier")

// Webhook
WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aggressive Entry","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aggressive Entry","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aggressive Entry","action":"CLOSE","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

// Indicators
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
rsi      = ta.rsi(close, rsi_len)
vol_sma  = ta.sma(volume, vol_sma_len)

// Volume Spike
vol_spike = volume > vol_sma * vol_mult

// EMA Crossovers
ema_cross_up   = ta.crossover(ema_fast, ema_slow)
ema_cross_down = ta.crossunder(ema_fast, ema_slow)

// RSI Conditions
rsi_above_50       = rsi > 50
rsi_below_50       = rsi < 50
rsi_cross_above_50 = ta.crossover(rsi,  50)
rsi_cross_below_50 = ta.crossunder(rsi, 50)

// Entry Conditions
long_entry  = ema_cross_up   and rsi_above_50 and vol_spike
short_entry = ema_cross_down and rsi_below_50 and vol_spike

// Exit Conditions
long_exit  = ema_cross_down or rsi_cross_below_50
short_exit = ema_cross_up   or rsi_cross_above_50

// Plots
plot(ema_fast, "EMA Fast", color=color.blue)
plot(ema_slow, "EMA Slow", color=color.orange)

// Strategy Execution
if long_entry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)

if short_entry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)

if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_alert)

if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_alert)
