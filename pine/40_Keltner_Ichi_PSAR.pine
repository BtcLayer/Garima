//@version=5
strategy("40_Keltner_Ichi_PSAR", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// close > Keltner mid + Ichimoku + PSAR + ADX — ALL 4 must agree
sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(4.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. Keltner mid (EMA20)
keltner_mid = ta.ema(close, 20)
keltner_atr = ta.atr(10)
keltner_upper = keltner_mid + 2 * keltner_atr
keltner_lower = keltner_mid - 2 * keltner_atr
sig_keltner = close > keltner_mid ? 1 : 0

// 2. Ichimoku above cloud
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
span_a = (tenkan + kijun) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
sig_ichi = (close > span_a and close > span_b) ? 1 : 0

// 3. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 4. ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// === ALL 4 must agree for entry ===
total_signals = sig_keltner + sig_ichi + sig_psar + sig_adx
long_entry = total_signals >= 4
exit_signal = total_signals < 2

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Keltner_Ichi_PSAR","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Keltner_Ichi_PSAR","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Keltner_Ichi_PSAR","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(keltner_mid, "Keltner Mid", color=color.blue)
plot(keltner_upper, "Keltner Upper", color=color.teal)
plot(keltner_lower, "Keltner Lower", color=color.teal)
plot(span_a, "Span A", color=color.green)
plot(span_b, "Span B", color=color.red)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 4 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
