//@version=5
strategy("16_Volume_Trend_ADX", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

sl_pct = input.float(1.8, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(10.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(1.8, "Trailing Stop %", step=0.1) / 100
min_agreement = input.int(3, "Min Signals Required", minval=1, maxval=5)

// Volume_Spike
vol_ma = ta.sma(volume, 20)
sig_volume = (volume > vol_ma * 1.5 and close > close[1]) ? 1 : 0

// Trend_MA50
ema50 = ta.ema(close, 50)
sig_trend = close > ema50 ? 1 : 0

// ADX_Trend
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// EMA_Cross
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// MACD_Cross
macd_line = ema21 - ema50
signal_line = ta.ema(macd_line, 9)
sig_macd = (macd_line > signal_line and macd_line[1] <= signal_line[1]) ? 1 : 0

total_signals = sig_volume + sig_trend + sig_adx + sig_ema + sig_macd
long_entry = total_signals >= min_agreement
exit_signal = total_signals < 1

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Volume_Trend_ADX","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Volume_Trend_ADX","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Volume_Trend_ADX","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

plot(ema50, "EMA50", color=color.purple)
bgcolor(total_signals >= min_agreement ? color.new(color.green, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
