//@version=5
strategy("alpha_01_ADAUSDT_4h", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// TIER_2_DEPLOY: PF=1.82 WR=57.9% GDD=6.7% ROI=38.9% Trades=76
// PSAR_EMA_ST_ADX_Trend_OBV on ADA 4h
// Custom: EMA 5/30, ATR mult=3.5, PSAR af=0.010, ADX>25
sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(1.5, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.8, "Trailing Stop %", step=0.1) / 100

// 1. PSAR Bull (af=0.010 — slower than default 0.02)
psar = ta.sar(0.010, 0.010, 0.2)
sig_psar = close > psar ? 1 : 0

// 2. EMA Cross (5/30 — faster fast, slower slow)
ema5 = ta.ema(close, 5)
ema30 = ta.ema(close, 30)
sig_ema = ema5 > ema30 ? 1 : 0

// 3. Supertrend (ATR mult=3.5 — wider than default 3.0)
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3.5 * atr14
sig_super = close > supertrend ? 1 : 0

// 4. ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// 5. Trend MA50
ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

// 6. OBV Rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

// ALL 6 must agree
total_signals = sig_psar + sig_ema + sig_super + sig_adx + sig_trend50 + sig_obv
long_entry = total_signals >= 6
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"alpha_01_ADAUSDT","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"alpha_01_ADAUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"alpha_01_ADAUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema5, "EMA5", color=color.blue)
plot(ema30, "EMA30", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 6 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
