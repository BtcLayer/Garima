//@version=5
// BB Squeeze V2 — HIGH TP VERSION
// Base has WR=82% PF=16.53 but only 26%/yr because TP is too conservative (4.5%)
// This version: push TP to 8-15%, keep tight SL, let winners run longer
// WR may drop but each win is BIGGER
strategy("BB Squeeze V2 HighTP", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── ADJUSTABLE PARAMS (try different combos) ──
sl_pct = input.float(1.5, "SL %", step=0.5) / 100
tp_pct = input.float(10.0, "TP % (higher = more profit per win)", step=1.0) / 100
trail_pct = input.float(3.0, "Trail % (locks profit)", step=0.5) / 100
bb_len = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Mult")
kc_mult = input.float(1.5, "KC Mult")

// ── SQUEEZE DETECTION ──
bb_basis = ta.sma(close, bb_len)
bb_dev = ta.stdev(close, bb_len) * bb_mult
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
kc_basis = ta.ema(close, bb_len)
kc_range = ta.atr(bb_len)
kc_upper = kc_basis + kc_mult * kc_range
kc_lower = kc_basis - kc_mult * kc_range

squeeze_on = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_release = not squeeze_on and squeeze_on[1]

// ── MOMENTUM (linreg) ──
highest_high = ta.highest(high, bb_len)
lowest_low = ta.lowest(low, bb_len)
delta = close - math.avg(math.avg(highest_high, lowest_low), bb_basis)
momentum = ta.linreg(delta, bb_len, 0)

// ── FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_ok = adx > 20
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
trend_up = ema50 > ema200
trend_down = ema50 < ema200

// ── ENTRY ──
long_signal = squeeze_release and momentum > 0 and adx_ok and vol_ok
short_signal = squeeze_release and momentum < 0 and adx_ok and vol_ok
long_strong = long_signal and trend_up and vol_confirm
short_strong = short_signal and trend_down and vol_confirm
long_entry = long_strong or (long_signal and momentum > momentum[1])
short_entry = short_strong or (short_signal and momentum < momentum[1])

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION WITH TRAILING STOP ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_Exit", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_Exit", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if momentum < 0 and strategy.position_size > 0
    strategy.close("Long")
if momentum > 0 and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
barcolor(squeeze_on ? color.red : color.new(color.green, 60))
bgcolor(squeeze_release ? color.new(color.yellow, 88) : na)
plot(bb_upper, "BB Up", color.blue, 1)
plot(bb_lower, "BB Lo", color.blue, 1)
plot(ema50, "EMA50", color.orange)
plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)

var table info = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "TP/SL", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(tp_pct * 100, "#.#") + "% / " + str.tostring(sl_pct * 100, "#.#") + "%", text_color=color.white, text_size=size.small)
    table.cell(info, 0, 1, "Squeeze", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, squeeze_on ? "ON (compressing)" : "OFF", text_color=squeeze_on ? color.red : color.green, text_size=size.small)
    table.cell(info, 0, 2, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(math.round(momentum, 2)), text_color=momentum > 0 ? color.green : color.red, text_size=size.small)
