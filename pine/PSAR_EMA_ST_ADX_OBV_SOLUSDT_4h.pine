//@version=5
strategy("alpha_02_SOLUSDT_4h", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// TIER_2_DEPLOY: PF=1.68 WR=53.3% GDD=7.4% ROI=28.8% Trades=90
// PSAR_EMA_ST_ADX_Trend_OBV on SOL 4h
// Custom: EMA 5/15, ATR mult=3.5, PSAR af=0.030, ADX>30
sl_pct = input.float(0.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(2.5, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.2, "Trailing Stop %", step=0.1) / 100

psar = ta.sar(0.030, 0.030, 0.2)
sig_psar = close > psar ? 1 : 0

ema5 = ta.ema(close, 5)
ema15 = ta.ema(close, 15)
sig_ema = ema5 > ema15 ? 1 : 0

atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3.5 * atr14
sig_super = close > supertrend ? 1 : 0

[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 30 ? 1 : 0

ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

total_signals = sig_psar + sig_ema + sig_super + sig_adx + sig_trend50 + sig_obv
long_entry = total_signals >= 6
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"alpha_02_SOLUSDT","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"alpha_02_SOLUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"alpha_02_SOLUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema5, "EMA5", color=color.blue)
plot(ema15, "EMA15", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
bgcolor(total_signals >= 6 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
