//@version=5
// RSI DIVERGENCE — Price makes new low but RSI makes higher low = bullish reversal
// This is one of the MOST RELIABLE patterns in technical analysis
// Combined with BB Squeeze V2 risk management
// Test on: ETHUSDT, BTCUSDT, DOTUSDT, LDOUSDT — 4h
strategy("RSI Divergence", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
rsi_len = input.int(14, "RSI Length")
pivot_lookback = input.int(5, "Pivot Lookback")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(10.0, "TP %") / 100
trail_pct = input.float(3.5, "Trail %") / 100

// ── RSI ──
rsi = ta.rsi(close, rsi_len)

// ── PIVOT DETECTION ──
pivot_low = ta.pivotlow(low, pivot_lookback, pivot_lookback)
pivot_high = ta.pivothigh(high, pivot_lookback, pivot_lookback)
rsi_pivot_low = ta.pivotlow(rsi, pivot_lookback, pivot_lookback)
rsi_pivot_high = ta.pivothigh(rsi, pivot_lookback, pivot_lookback)

// ── DIVERGENCE DETECTION ──
// Store previous pivot values
var float prev_price_low = na
var float prev_rsi_low = na
var float prev_price_high = na
var float prev_rsi_high = na

// Update on new pivots
if not na(pivot_low)
    prev_price_low := low[pivot_lookback]
if not na(rsi_pivot_low)
    prev_rsi_low := rsi[pivot_lookback]
if not na(pivot_high)
    prev_price_high := high[pivot_lookback]
if not na(rsi_pivot_high)
    prev_rsi_high := rsi[pivot_lookback]

// Bullish divergence: price lower low + RSI higher low
bull_div = not na(pivot_low) and not na(prev_price_low) and low[pivot_lookback] < prev_price_low and not na(prev_rsi_low) and rsi[pivot_lookback] > prev_rsi_low and rsi < 45

// Bearish divergence: price higher high + RSI lower high
bear_div = not na(pivot_high) and not na(prev_price_high) and high[pivot_lookback] > prev_price_high and not na(prev_rsi_high) and rsi[pivot_lookback] < prev_rsi_high and rsi > 55

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.1

// Tiered
long_strong = bull_div and vol_confirm and close > ema200 and adx > 20
long_medium = bull_div and close > ema50
short_strong = bear_div and vol_confirm and close < ema200 and adx > 20
short_medium = bear_div and close < ema50

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
ema20 = ta.ema(close, 20)
long_exit = rsi > 75 or (close < ema20 and close[1] >= ema20[1])
short_exit = rsi < 25 or (close > ema20 and close[1] <= ema20[1])

// ── ANTI-OVERTRADING (BB Squeeze V2 style) ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION with TRAILING STOP ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Bull Div", shape.triangleup, location.belowbar, color.lime, size=size.small, text="DIV")
plotshape(short_entry and can_trade, "Bear Div", shape.triangledown, location.abovebar, color.red, size=size.small, text="DIV")
