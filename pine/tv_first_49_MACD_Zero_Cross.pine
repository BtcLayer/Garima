//@version=5
// MACD ZERO LINE CROSS — MACD crossing zero = trend confirmation
// More reliable than signal line cross — fewer false signals
// Combined with ADX + volume for high probability entries
strategy("MACD Zero Cross", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

fast = input.int(12, "MACD Fast")
slow = input.int(26, "MACD Slow")
sig = input.int(9, "Signal")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

[macd_line, signal_line, hist] = ta.macd(close, fast, slow, sig)
zero_cross_up = ta.crossover(macd_line, 0)
zero_cross_down = ta.crossunder(macd_line, 0)
hist_rising = hist > hist[1] and hist[1] > hist[2]
hist_falling = hist < hist[1] and hist[1] < hist[2]

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
vol_ok = atr14 < ta.sma(atr14, 100) * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

long_strong = zero_cross_up and hist_rising and close > ema50 and adx > 25 and vol_confirm
long_medium = zero_cross_up and close > ema50 and adx > 18
short_strong = zero_cross_down and hist_falling and close < ema50 and adx > 25 and vol_confirm
short_medium = zero_cross_down and close < ema50 and adx > 18

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

long_exit = zero_cross_down or (hist < 0 and hist[1] >= 0)
short_exit = zero_cross_up or (hist > 0 and hist[1] <= 0)

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
