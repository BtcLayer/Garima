//@version=5
// TRIX SIGNAL — Triple Smoothed EMA momentum
// TRIX eliminates noise through triple smoothing — very clean signals
// TRIX cross above signal line = trend starting
// Test on: ETHUSDT, BTCUSDT, DOTUSDT, LDOUSDT, SOLUSDT, SUIUSDT — 4h
strategy("TRIX Signal", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
trix_len = input.int(14, "TRIX Length")
signal_len = input.int(9, "Signal Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// ── TRIX ──
ema1 = ta.ema(close, trix_len)
ema2 = ta.ema(ema1, trix_len)
ema3 = ta.ema(ema2, trix_len)
trix_val = (ema3 - ema3[1]) / ema3[1] * 10000
trix_signal = ta.ema(trix_val, signal_len)

trix_cross_up = ta.crossover(trix_val, trix_signal)
trix_cross_down = ta.crossunder(trix_val, trix_signal)
trix_above_zero = trix_val > 0
trix_below_zero = trix_val < 0

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// Tiered
long_strong = trix_cross_up and trix_above_zero and close > ema50 and adx > 25 and vol_confirm
long_medium = trix_cross_up and close > ema50 and adx > 18
short_strong = trix_cross_down and trix_below_zero and close < ema50 and adx > 25 and vol_confirm
short_medium = trix_cross_down and close < ema50 and adx > 18

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = trix_cross_down and trix_val < 0
short_exit = trix_cross_up and trix_val > 0

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct), limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct), limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="TRIX")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="TRIX")
