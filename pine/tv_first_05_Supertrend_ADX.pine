//@version=5
// TV-FIRST Strategy 05: Supertrend + ADX + RSI Confirmation
// Test on: NEARUSDT, FILUSDT, LDOUSDT, OPUSDT — 15m timeframe
strategy("Supertrend ADX Pro", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// Inputs
st_mult = input.float(2.0, "Supertrend Multiplier", step=0.1)
st_len = input.int(14, "Supertrend Length")
adx_thresh = input.int(20, "ADX Threshold")

// Supertrend
[st_val, st_dir] = ta.supertrend(st_mult, st_len)
st_bull = close > st_val
st_bear = close < st_val
st_flip_bull = st_bull and not st_bull[1]
st_flip_bear = st_bear and not st_bear[1]

// RSI + ADX
rsi = ta.rsi(close, 14)
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_ok = adx > adx_thresh

// ATR filter
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// Entry: Supertrend flip + ADX trending + RSI confirms
long_entry = st_flip_bull and rsi > 45 and adx_ok and vol_ok
short_entry = st_flip_bear and rsi < 55 and adx_ok and vol_ok

// Exit: opposite flip or RSI extreme
long_exit = st_flip_bear
short_exit = st_flip_bull

// Execution
if long_entry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
if short_entry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// Visuals
plot(st_val, "Supertrend", st_bull ? color.green : color.red, 2)
plotshape(long_entry, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.tiny)
plotshape(short_entry, "Sell", shape.triangledown, location.abovebar, color.red, size=size.tiny)
