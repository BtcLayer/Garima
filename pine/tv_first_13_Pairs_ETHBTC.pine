//@version=5
// PAIRS TRADING — ETH/BTC Ratio Mean Reversion
// When ETH is cheap vs BTC (ratio below mean) → long ETH
// When ETH is expensive vs BTC (ratio above mean) → short ETH
// Market neutral approach — works in bull, bear, and sideways
// Test on: ETHUSDT chart (uses BTCUSDT as reference)
strategy("Pairs ETH/BTC", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
ratio_len = input.int(50, "Rolling Mean Length")
z_entry = input.float(1.5, "Z-Score Entry", step=0.1)
z_exit = input.float(0.5, "Z-Score Exit", step=0.1)
sl_pct = input.float(3.0, "SL %") / 100
tp_pct = input.float(5.0, "TP %") / 100

// ── BTC PRICE ──
btc_close = request.security("BINANCE:BTCUSDT", timeframe.period, close)

// ── RATIO: ETH / BTC ──
ratio = close / btc_close

// ── Z-SCORE of ratio ──
ratio_mean = ta.sma(ratio, ratio_len)
ratio_std = ta.stdev(ratio, ratio_len)
z_score = (ratio - ratio_mean) / ratio_std

// ── FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// ── ENTRY ──
// ETH cheap vs BTC (z < -1.5) → long ETH (expect reversion up)
long_entry = z_score < -z_entry and z_score[1] >= -z_entry and vol_ok
// ETH expensive vs BTC (z > 1.5) → short ETH (expect reversion down)
short_entry = z_score > z_entry and z_score[1] <= z_entry and vol_ok

// ── EXIT: z-score returns to mean ──
long_exit = z_score > z_exit
short_exit = z_score < -z_exit

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int cooldown = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 4
can_trade = trades_today < 2 and cooldown == 0

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_SL", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_SL", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))

if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
hline(0, "Zero", color.gray)
plot(z_score, "Z-Score", z_score > z_entry ? color.red : z_score < -z_entry ? color.green : color.gray, 2)
bgcolor(z_score < -z_entry ? color.new(color.green, 90) : z_score > z_entry ? color.new(color.red, 90) : na)

var table info = table.new(position.top_right, 2, 3, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "Z-Score", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(math.round(z_score, 2)), text_color=math.abs(z_score) > z_entry ? color.yellow : color.gray, text_size=size.small)
    table.cell(info, 0, 1, "ETH/BTC Ratio", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(math.round(ratio, 6)), text_color=color.white, text_size=size.small)
    table.cell(info, 0, 2, "Mean", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(math.round(ratio_mean, 6)), text_color=color.white, text_size=size.small)
