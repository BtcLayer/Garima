//@version=5
strategy("alpha_04_ETHUSDT_4h", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// TIER_2_DEPLOY: PF=1.66 WR=50.0% GDD=9.6% ROI=66.7% Trades=160
// Ichi_OBV_Vol_PSAR_Trend on ETH 4h
// Custom: Ichimoku 9/22, Volume 2x, PSAR af=0.030
sl_pct = input.float(0.5, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(5.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.2, "Trailing Stop %", step=0.1) / 100

// 1. Ichimoku Bull (tenkan=9, kijun=22 — custom kijun)
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 22) + ta.lowest(low, 22)) / 2
span_a = (tenkan + kijun) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
sig_ichi = (close > span_a and close > span_b) ? 1 : 0

// 2. OBV Rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

// 3. Volume Spike (2.0x)
vol_ma = ta.sma(volume, 20)
sig_vol = (volume > vol_ma * 2.0 and close > close[1]) ? 1 : 0

// 4. PSAR Bull (af=0.030)
psar = ta.sar(0.030, 0.030, 0.2)
sig_psar = close > psar ? 1 : 0

// 5. Trend MA50
ema50 = ta.ema(close, 50)
sig_trend50 = close > ema50 ? 1 : 0

total_signals = sig_ichi + sig_obv + sig_vol + sig_psar + sig_trend50
long_entry = total_signals >= 5
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"alpha_04_ETHUSDT","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"alpha_04_ETHUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"alpha_04_ETHUSDT","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(span_a, "Span A", color=color.green)
plot(span_b, "Span B", color=color.red)
plot(ema50, "EMA50", color=color.purple)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
