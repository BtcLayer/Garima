//@version=5
strategy("03_EMA_Break_Momentum", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// === INPUTS ===
sl_pct = input.float(2.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(15.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(2.5, "Trailing Stop %", step=0.1) / 100
min_agreement = input.int(2, "Min Signals Required", minval=1, maxval=4)

// === INDICATORS (match Python exactly) ===
// 1. EMA_Cross: EMA8 > EMA21 (persistent)
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// 2. Breakout_20: price > 20-bar high of previous bars (persistent)
high_20 = ta.highest(high[1], 20)
sig_breakout = close > high_20 ? 1 : 0

// 3. MACD_Cross: MACD line crosses above signal (momentary)
// Python MACD = EMA21 - EMA50, signal = EMA9 of MACD
ema50 = ta.ema(close, 50)
macd_line = ema21 - ema50
signal_line = ta.ema(macd_line, 9)
sig_macd = (macd_line > signal_line and macd_line[1] <= signal_line[1]) ? 1 : 0

// 4. ADX_Trend: ADX > 25 (persistent)
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// === SIGNAL AGREEMENT ===
total_signals = sig_ema + sig_breakout + sig_macd + sig_adx
long_entry = total_signals >= min_agreement
exit_signal = total_signals < 1

// === STRATEGY EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"EMA_Break_Momentum","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long",
         stop=strategy.position_avg_price * (1 - sl_pct),
         limit=strategy.position_avg_price * (1 + tp_pct),
         trail_points=1,
         trail_offset=trail_ticks,
         alert_message='{"strategy":"EMA_Break_Momentum","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"EMA_Break_Momentum","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"sl_pct":0,"tp_pct":0,"ts_pct":0,"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(high_20, "20-bar High", color=color.gray, style=plot.style_stepline)
bgcolor(total_signals >= min_agreement ? color.new(color.green, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
