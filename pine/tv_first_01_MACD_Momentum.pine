//@version=5
// TV-FIRST Strategy 01: MACD Momentum + EMA Trend + ADX Filter
// Test on: NEARUSDT, FILUSDT, LDOUSDT, OPUSDT — 15m timeframe
strategy("MACD Momentum Pro", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// Inputs
ema_fast = input.int(9, "EMA Fast")
ema_slow = input.int(21, "EMA Slow")
ema_trend = input.int(200, "EMA Trend")
adx_thresh = input.int(20, "ADX Threshold")
sl_pct = input.float(1.0, "SL %") / 100
tp_pct = input.float(3.0, "TP %") / 100

// Indicators
fast = ta.ema(close, ema_fast)
slow = ta.ema(close, ema_slow)
trend = ta.ema(close, ema_trend)
[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)
[diplus, diminus, adx] = ta.dmi(14, 14)

// Conditions
macd_bull = ta.crossover(macd_line, signal_line)
macd_bear = ta.crossunder(macd_line, signal_line)
trend_up = close > trend
trend_down = close < trend
adx_ok = adx > adx_thresh

// ATR volatility filter
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// Entry
long_entry = macd_bull and trend_up and adx_ok and vol_ok
short_entry = macd_bear and trend_down and adx_ok and vol_ok

// Exit
long_exit = macd_bear or close < trend
short_exit = macd_bull or close > trend

// Execution
if long_entry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_SL", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))

if short_entry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_SL", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))

if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// Visuals
plot(fast, "Fast", color.blue)
plot(slow, "Slow", color.orange)
plot(trend, "Trend", color.gray)
plotshape(long_entry, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.tiny)
plotshape(short_entry, "Sell", shape.triangledown, location.abovebar, color.red, size=size.tiny)
