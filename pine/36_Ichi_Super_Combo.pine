//@version=5
strategy("36_Ichi_Super_Combo", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Ichimoku + Tenkan/Kijun + Supertrend + PSAR + ADX — ALL 5 must agree
sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(5.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. Ichimoku above cloud
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
span_a = (tenkan + kijun) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
sig_ichi = (close > span_a and close > span_b) ? 1 : 0

// 2. Tenkan > Kijun
sig_tk = tenkan > kijun ? 1 : 0

// 3. Supertrend
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
sig_super = close > supertrend ? 1 : 0

// 4. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 5. ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// === ALL 5 must agree for entry ===
total_signals = sig_ichi + sig_tk + sig_super + sig_psar + sig_adx
long_entry = total_signals >= 5
exit_signal = total_signals < 3

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Ichi_Super_Combo","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Ichi_Super_Combo","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Ichi_Super_Combo","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(tenkan, "Tenkan", color=color.blue)
plot(kijun, "Kijun", color=color.orange)
plot(span_a, "Span A", color=color.green)
plot(span_b, "Span B", color=color.red)
plot(supertrend, "Supertrend", color=color.teal)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
