//@version=5
strategy("53_Cloud_Break_v2", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Based on 47_Cloud_Break_Volume with tighter TP, wider SL + OBV_Rising + EMA_Cross filters
// Cloud Breakout + Volume 1.5x + ADX + PSAR + OBV_Rising + EMA_Cross — 5 of 6 must agree
sl_pct = input.float(2.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(3.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. Ichimoku Cloud Breakout (was below, now above)
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
span_a = (tenkan + kijun) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
above_cloud = close > span_a and close > span_b
was_below = close[1] < span_a[1] or close[1] < span_b[1]
cloud_breakout = above_cloud and was_below
// Stay in trade while above cloud (persistent after breakout)
sig_ichi = above_cloud ? 1 : 0

// 2. Volume > 1.5x average
vol_sma = ta.sma(volume, 20)
sig_vol = volume > vol_sma * 1.5 ? 1 : 0

// 3. ADX > 25
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 25 ? 1 : 0

// 4. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 5. OBV Rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

// 6. EMA Cross (EMA8 > EMA21)
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
sig_ema = ema8 > ema21 ? 1 : 0

// === Entry requires cloud breakout + 5 of 6 persistent signals ===
total_signals = sig_ichi + sig_vol + sig_adx + sig_psar + sig_obv + sig_ema
long_entry = cloud_breakout and total_signals >= 5
exit_signal = total_signals < 3

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Cloud_Break_v2","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Cloud_Break_v2","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Cloud_Break_v2","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(tenkan, "Tenkan", color=color.blue)
plot(kijun, "Kijun", color=color.orange)
plot(span_a, "Span A", color=color.green)
plot(span_b, "Span B", color=color.red)
plot(ema8, "EMA8", color=color.teal)
plot(ema21, "EMA21", color=color.maroon)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(above_cloud ? color.new(color.green, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(cloud_breakout, "Cloud Breakout", shape.diamond, location.abovebar, color.lime, size=size.tiny)
