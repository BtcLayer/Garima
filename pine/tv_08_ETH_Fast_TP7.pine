//@version=5
// Target: 1%/day + PF>=1.4 + WR>=50%
// Fast EMA(5/15) + PSAR(0.03) + Supertrend(ATR*3.5) + ADX>30 + OBV, ALL 5 agree
// TP=7%, SL=1%, TS=0.5%
strategy("tv_08_ETH_Fast_TP7", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(7.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// Fast EMA 5/15
ema5 = ta.ema(close, 5)
ema15 = ta.ema(close, 15)
sig_ema = ema5 > ema15 ? 1 : 0

// PSAR (faster af=0.03)
psar = ta.sar(0.03, 0.03, 0.2)
sig_psar = close > psar ? 1 : 0

// Supertrend ATR*3.5
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3.5 * atr14
sig_super = close > supertrend ? 1 : 0

// ADX > 30
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = (adx_val > 30 and diplus > diminus) ? 1 : 0

// OBV Rising
obv = ta.obv
obv_ma = ta.sma(obv, 20)
sig_obv = obv > obv_ma ? 1 : 0

total_signals = sig_ema + sig_psar + sig_super + sig_adx + sig_obv
long_entry = total_signals >= 5
exit_signal = total_signals < 3

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"tv_08_ETH_Fast_TP7","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"tv_08_ETH_Fast_TP7","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"tv_08_ETH_Fast_TP7","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

plot(ema5, "EMA5", color=color.blue)
plot(ema15, "EMA15", color=color.orange)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 5 ? color.new(color.green, 85) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
