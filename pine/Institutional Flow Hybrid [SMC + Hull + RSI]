//@version=5
strategy("Institutional Flow Hybrid [SMC + Hull + RSI] - WEBHOOK", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// --- INPUTS ---
// Webhook Configuration
grp_webhook = "🔔 Webhook Configuration"
enable_webhook = input.bool(true, "Enable Webhook Alerts", group=grp_webhook)
webhook_secret = input.string("hybrid_tradingview_cluster_2026_secure", "Webhook Secret", group=grp_webhook, tooltip="Must match bot configuration")

// Trend Filter (Hull Suite)
h_len = input.int(55, "Hull Length")
h_mult = input.float(1.0, "Hull Multiplier", tooltip="Multiplier for trend strength bands")

// Momentum Filter (RSI)
rsi_len = input.int(14, "RSI Length")
rsi_upper = input.int(55, "RSI Bullish Zone", tooltip="Lowered for better signal capture")
rsi_lower = input.int(45, "RSI Bearish Zone", tooltip="Raised for better signal capture")

// Market Structure
smc_lookback = input.int(20, "Structure Lookback", tooltip="Bars to look back for structure breaks")

// Risk Management
use_atr_stops = input.bool(true, "Use ATR-Based Stops", tooltip="More adaptive than fixed percentages")
atr_length = input.int(14, "ATR Length")
atr_multiplier = input.float(2.0, "ATR Stop Multiplier")
tp_percent = input.float(2.0, "Take Profit %", tooltip="Used if ATR stops disabled")
sl_percent = input.float(1.5, "Stop Loss %", tooltip="Used if ATR stops disabled")

// --- LOGIC ---
// 1. Hull Suite Trend with Bands
hull_val = ta.wma(2 * ta.wma(close, h_len / 2) - ta.wma(close, h_len), math.floor(math.sqrt(h_len)))
atr = ta.atr(atr_length)
hull_upper = hull_val + (atr * h_mult)
hull_lower = hull_val - (atr * h_mult)
hull_trend = hull_val > hull_val[1] ? 1 : -1
hull_color = hull_trend == 1 ? color.green : color.red

// 2. RSI Momentum
rsi = ta.rsi(close, rsi_len)
rsi_bullish = rsi > rsi_upper or (rsi > 50 and rsi > rsi[1])
rsi_bearish = rsi < rsi_lower or (rsi < 50 and rsi < rsi[1])

// 3. Market Structure (Improved Break of Structure)
// Track swing highs and lows more accurately
var float last_swing_high = na
var float last_swing_low = na

higher_high = ta.highest(high, smc_lookback)
lower_low = ta.lowest(low, smc_lookback)

// Detect actual structure breaks (price must break AND close beyond previous structure)
bos_long = high > higher_high[1] and close > higher_high[1] and hull_trend == 1
bos_short = low < lower_low[1] and close < lower_low[1] and hull_trend == -1

// Update swing points
if bos_long
    last_swing_high := high
if bos_short
    last_swing_low := low

// --- CONFLUENCE SIGNALS ---
// All conditions must align: Structure + Trend + Momentum
long_condition = bos_long and hull_trend == 1 and rsi_bullish
short_condition = bos_short and hull_trend == -1 and rsi_bearish

// --- Calculate TP/SL Levels ---
float long_sl = na
float long_tp = na
float short_sl = na
float short_tp = na

// Calculate stops based on method
if use_atr_stops
    long_sl := close - (atr * atr_multiplier)
    long_tp := close + (atr * atr_multiplier * (tp_percent / sl_percent)) // Risk:Reward ratio maintained
    short_sl := close + (atr * atr_multiplier)
    short_tp := close - (atr * atr_multiplier * (tp_percent / sl_percent))
else
    long_sl := close * (1 - sl_percent/100)
    long_tp := close * (1 + tp_percent/100)
    short_sl := close * (1 + sl_percent/100)
    short_tp := close * (1 - tp_percent/100)

// Convert timeframe to lowercase for webhook
tf_lower = timeframe.period == "1D" ? "1d" : 
           timeframe.period == "4H" or timeframe.period == "240" ? "4h" : 
           timeframe.period == "1H" or timeframe.period == "60" ? "1h" : 
           timeframe.period == "30" ? "30m" : 
           timeframe.period == "15" ? "15m" : 
           timeframe.period == "5" ? "5m" : 
           timeframe.period == "1" ? "1m" : 
           timeframe.period == "10S" or timeframe.period == "10" ? "10s" :
           timeframe.period == "5S" or timeframe.period == "5" ? "5s" :
           str.replace_all(str.lower(timeframe.period), "S", "s")

// --- EXECUTION WITH WEBHOOK ---
if (long_condition)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", limit=long_tp, stop=long_sl)
    
    if enable_webhook
        alert('{"secret":"' + webhook_secret + '","strategy":"institutional_flow_hybrid","side":"BUY","symbol":"' + syminfo.ticker + '","timeframe":"' + tf_lower + '","price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(long_sl) + ',"take_profit":' + str.tostring(long_tp) + ',"rsi":' + str.tostring(rsi) + ',"hull_trend":' + str.tostring(hull_trend) + '}', alert.freq_once_per_bar_close)

if (short_condition)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", limit=short_tp, stop=short_sl)
    
    if enable_webhook
        alert('{"secret":"' + webhook_secret + '","strategy":"institutional_flow_hybrid","side":"SELL","symbol":"' + syminfo.ticker + '","timeframe":"' + tf_lower + '","price":' + str.tostring(close) + ',"stop_loss":' + str.tostring(short_sl) + ',"take_profit":' + str.tostring(short_tp) + ',"rsi":' + str.tostring(rsi) + ',"hull_trend":' + str.tostring(hull_trend) + '}', alert.freq_once_per_bar_close)

// --- VISUALS ---
// Hull Trend with Bands
plot(hull_val, color=hull_color, linewidth=3, title="Institutional Trend")
plot(hull_upper, color=color.new(hull_color, 70), linewidth=1, title="Upper Band")
plot(hull_lower, color=color.new(hull_color, 70), linewidth=1, title="Lower Band")

// Background coloring
bgcolor(long_condition ? color.new(color.green, 90) : short_condition ? color.new(color.red, 90) : na)

// Signal markers
plotshape(long_condition, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="Long Signal")
plotshape(short_condition, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="Short Signal")

// TP/SL levels for active positions
plot(strategy.position_size > 0 ? long_tp : na, color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2, title="Long TP")
plot(strategy.position_size > 0 ? long_sl : na, color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2, title="Long SL")
plot(strategy.position_size < 0 ? short_tp : na, color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2, title="Short TP")
plot(strategy.position_size < 0 ? short_sl : na, color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2, title="Short SL")
