//@version=5
// TV-FIRST Strategy 02: Keltner Breakout + RSI Momentum
// Test on: NEARUSDT, FILUSDT, LDOUSDT, OPUSDT — 15m timeframe
strategy("Keltner RSI Breakout", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// Inputs
kc_len = input.int(20, "KC Length")
kc_mult = input.float(1.8, "KC Multiplier", step=0.1)
rsi_len = input.int(14, "RSI Length")
adx_thresh = input.int(20, "ADX Threshold")

// Keltner Channel
basis = ta.ema(close, kc_len)
kc_atr = ta.atr(kc_len)
upper = basis + kc_mult * kc_atr
lower = basis - kc_mult * kc_atr

// RSI + ADX
rsi = ta.rsi(close, rsi_len)
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_ok = adx > adx_thresh

// ATR filter
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

// Entry: breakout + RSI confirmation + ADX trending
long_entry = ta.crossover(close, upper) and rsi > 55 and adx_ok and vol_ok
short_entry = ta.crossunder(close, lower) and rsi < 45 and adx_ok and vol_ok

// Exit: return to midline or opposite channel
long_exit = close < basis or ta.crossunder(close, lower)
short_exit = close > basis or ta.crossover(close, upper)

// Execution
if long_entry and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
if short_entry and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// Visuals
plot(basis, "Basis", color.orange)
plot(upper, "Upper", color.blue)
plot(lower, "Lower", color.blue)
plotshape(long_entry, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.tiny)
plotshape(short_entry, "Sell", shape.triangledown, location.abovebar, color.red, size=size.tiny)
