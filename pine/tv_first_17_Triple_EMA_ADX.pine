//@version=5
// Triple EMA + ADX — 3 EMAs aligned + strong trend confirmation
// Simple but strict: all 3 EMAs must agree + ADX must be strong
// Test on: ETHUSDT, BTCUSDT, ADAUSDT, LTCUSDT — 4h
strategy("Triple EMA ADX", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)

// All 3 EMAs aligned + ADX strong
bull_aligned = ema8 > ema21 and ema21 > ema50 and adx > 25 and atr14 < atr_ma * 2
bear_aligned = ema8 < ema21 and ema21 < ema50 and adx > 25 and atr14 < atr_ma * 2

// Entry on fresh alignment (not every bar)
long_entry = bull_aligned and not bull_aligned[1] and rsi > 45 and rsi < 70
short_entry = bear_aligned and not bear_aligned[1] and rsi < 55 and rsi > 30

var int trades_today = 0
var int cooldown = 0
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 4
can_trade = trades_today < 3 and cooldown == 0

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close * 0.97, limit=close * 1.06)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close * 1.03, limit=close * 0.94)
if not bull_aligned and strategy.position_size > 0
    strategy.close("Long")
if not bear_aligned and strategy.position_size < 0
    strategy.close("Short")

plot(ema8, "EMA8", color.blue)
plot(ema21, "EMA21", color.orange)
plot(ema50, "EMA50", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
