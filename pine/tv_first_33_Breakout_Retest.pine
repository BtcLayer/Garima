//@version=5
// BREAKOUT + RETEST — Professional institutional pattern
// Price breaks key level → pulls back → enters on the retest
// This avoids false breakouts (biggest killer of breakout strategies)
// BB Squeeze V2 risk management applied
// Test on: ETHUSDT, BTCUSDT, DOTUSDT, LDOUSDT — 4h
strategy("Breakout Retest", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
lookback = input.int(20, "Lookback for Levels")
retest_bars = input.int(5, "Retest Window (bars)")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(10.0, "TP %") / 100
trail_pct = input.float(3.5, "Trail %") / 100

// ── KEY LEVELS (swing highs/lows) ──
swing_high = ta.highest(high, lookback)
swing_low = ta.lowest(low, lookback)

// ── BREAKOUT DETECTION ──
// Price closes above previous swing high = bullish breakout
broke_above = close > swing_high[1] and close[1] <= swing_high[2]
broke_below = close < swing_low[1] and close[1] >= swing_low[2]

// Track breakout state
var bool recent_break_up = false
var bool recent_break_down = false
var int break_bar = 0
var float break_level = na

if broke_above
    recent_break_up := true
    recent_break_down := false
    break_bar := bar_index
    break_level := swing_high[1]

if broke_below
    recent_break_down := true
    recent_break_up := false
    break_bar := bar_index
    break_level := swing_low[1]

// Reset if too many bars passed
bars_since_break = bar_index - break_bar
if bars_since_break > retest_bars * 3
    recent_break_up := false
    recent_break_down := false

// ── RETEST DETECTION ──
// After breakout, price pulls back to the broken level and bounces
retest_long = recent_break_up and bars_since_break >= 2 and bars_since_break <= retest_bars * 2 and low <= break_level * 1.005 and close > break_level and close > open
retest_short = recent_break_down and bars_since_break >= 2 and bars_since_break <= retest_bars * 2 and high >= break_level * 0.995 and close < break_level and close < open

// ── CONFIRMATION FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
ema50 = ta.ema(close, 50)

long_entry = retest_long and adx > 20 and vol_ok and rsi < 70 and close > ema50
short_entry = retest_short and adx > 20 and vol_ok and rsi > 30 and close < ema50

// Clear breakout after entry
if long_entry
    recent_break_up := false
if short_entry
    recent_break_down := false

// ── EXIT ──
long_exit = close < ema50 or rsi > 80
short_exit = close > ema50 or rsi < 20

// ── ANTI-OVERTRADING (BB Squeeze V2 style) ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION with TRAILING STOP ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plot(not na(break_level) and (recent_break_up or recent_break_down) ? break_level : na, "Break Level", color.yellow, 2, plot.style_circles)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="RT")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="RT")
