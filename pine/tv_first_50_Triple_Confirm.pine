//@version=5
// TRIPLE CONFIRM — 3 independent systems must ALL agree
// Donchian breakout + CCI > 100 + Supertrend bullish = enter
// Highest conviction setup — fewer trades but highest quality
strategy("Triple Confirm", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(14.0, "TP %") / 100
trail_pct = input.float(4.5, "Trail %") / 100

// System 1: Donchian
don_upper = ta.highest(high, 20)
don_lower = ta.lowest(low, 20)
don_bull = close > don_upper[1]
don_bear = close < don_lower[1]

// System 2: CCI
cci = ta.cci(close, 20)
cci_bull = cci > 100
cci_bear = cci < -100

// System 3: Supertrend
[st_val, st_dir] = ta.supertrend(3.0, 10)
st_bull = st_dir == -1
st_bear = st_dir == 1

// All three agree
triple_long = don_bull and cci_bull and st_bull
triple_short = don_bear and cci_bear and st_bear

// Or 2 of 3 with volume
two_of_three_long = ((don_bull and cci_bull) or (don_bull and st_bull) or (cci_bull and st_bull))
two_of_three_short = ((don_bear and cci_bear) or (don_bear and st_bear) or (cci_bear and st_bear))

ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
vol_ok = atr14 < ta.sma(atr14, 100) * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

long_entry = (triple_long or (two_of_three_long and vol_confirm)) and close > ema50 and adx > 20 and vol_ok
short_entry = (triple_short or (two_of_three_short and vol_confirm)) and close < ema50 and adx > 20 and vol_ok

// Exit when 2 of 3 systems flip
long_exit = (don_bear and cci_bear) or (don_bear and st_bear) or (cci_bear and st_bear)
short_exit = (don_bull and cci_bull) or (don_bull and st_bull) or (cci_bull and st_bull)

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(don_upper, "Don Hi", color.green)
plot(don_lower, "Don Lo", color.red)
plot(st_val, "ST", color=st_dir==-1?color.lime:color.orange, linewidth=2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="3X")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="3X")
