//@version=5
// BB SQUEEZE V3 — ENHANCED with Kelly Sizing + Wick Filter + Trend Strength
// Merges: BB Squeeze V2 (winner) + Kelly Criterion + Wick Theory + ADX strength
// Key improvements over V2:
//   1. Kelly-based position sizing (bet more on strong setups)
//   2. Wick rejection filter (confirm with candle pattern)
//   3. Trend strength scoring (multi-factor)
//   4. Momentum acceleration check
// Test on: LDOUSDT, ETHUSDT, BTCUSDT, SUIUSDT, DOTUSDT — 4h
strategy("BB Squeeze V3 Enhanced", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
bb_len = input.int(14, "BB Length")
bb_mult = input.float(2.0, "BB Mult")
kc_mult = input.float(1.5, "KC Mult")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100
use_kelly = input.bool(true, "Use Kelly Position Sizing")
use_wick_filter = input.bool(true, "Use Wick Confirmation")

// ── SQUEEZE DETECTION ──
bb_basis = ta.sma(close, bb_len)
bb_dev = ta.stdev(close, bb_len) * bb_mult
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
kc_basis = ta.ema(close, bb_len)
kc_range = ta.atr(bb_len)
kc_upper = kc_basis + kc_mult * kc_range
kc_lower = kc_basis - kc_mult * kc_range

squeeze_on = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_release = not squeeze_on and squeeze_on[1]

// ── MOMENTUM (linreg) ──
highest_high = ta.highest(high, bb_len)
lowest_low = ta.lowest(low, bb_len)
delta = close - math.avg(math.avg(highest_high, lowest_low), bb_basis)
momentum = ta.linreg(delta, bb_len, 0)
mom_accel = momentum > momentum[1]  // momentum accelerating

// ── WICK FILTER (Wick Theory) ──
body = math.abs(close - open)
total_range = high - low
lower_wick = math.min(close, open) - low
upper_wick = high - math.max(close, open)

// Bullish wick: long lower shadow (buyers stepped in)
bull_wick = lower_wick > body * 1.5 and close > open
// Bearish wick: long upper shadow (sellers stepped in)
bear_wick = upper_wick > body * 1.5 and close < open
// Bullish engulfing
bull_engulf = close > open and close > open[1] and open < close[1] and close[1] < open[1]

wick_bull_ok = not use_wick_filter or bull_wick or bull_engulf or (close > open and body > total_range * 0.5)
wick_bear_ok = not use_wick_filter or bear_wick or (close < open and body > total_range * 0.5)

// ── TREND STRENGTH SCORE (0-6) ──
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
obv = ta.cum(math.sign(ta.change(close)) * volume)
obv_sma = ta.sma(obv, 20)

trend_score_bull = (ema50 > ema200 ? 1 : 0) + (close > ema50 ? 1 : 0) + (adx > 20 ? 1 : 0) + (rsi > 45 and rsi < 75 ? 1 : 0) + (obv > obv_sma ? 1 : 0) + (mom_accel ? 1 : 0)
trend_score_bear = (ema50 < ema200 ? 1 : 0) + (close < ema50 ? 1 : 0) + (adx > 20 ? 1 : 0) + (rsi < 55 and rsi > 25 ? 1 : 0) + (obv < obv_sma ? 1 : 0) + (mom_accel ? 1 : 0)

// ── FILTERS ──
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// ── KELLY POSITION SIZING ──
// Based on historical WR of BB Squeeze (~82%) and TP/SL ratio
kelly_wr = 0.82
kelly_rr = tp_pct / sl_pct
kelly_pct = ((kelly_rr * kelly_wr) - (1 - kelly_wr)) / kelly_rr
half_kelly = kelly_pct / 2
position_size = use_kelly ? math.min(half_kelly * 100, 95) : 95

// ── ENTRY SIGNALS ──
long_signal = squeeze_release and momentum > 0 and vol_ok and trend_score_bull >= 3
short_signal = squeeze_release and momentum < 0 and vol_ok and trend_score_bear >= 3

// Apply wick filter
long_entry = long_signal and wick_bull_ok
short_entry = short_signal and wick_bear_ok

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, qty=strategy.equity * position_size / 100 / close)
    strategy.exit("L_Exit", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, qty=strategy.equity * position_size / 100 / close)
    strategy.exit("S_Exit", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if momentum < 0 and strategy.position_size > 0
    strategy.close("Long")
if momentum > 0 and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
barcolor(squeeze_on ? color.red : color.new(color.green, 60))
bgcolor(squeeze_release ? color.new(color.yellow, 88) : na)
plot(bb_upper, "BB Up", color.blue, 1)
plot(bb_lower, "BB Lo", color.blue, 1)
plot(ema50, "EMA50", color.orange)
plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)

// Score + Kelly display
var table info = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(info, 0, 0, "Trend Score", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, str.tostring(trend_score_bull) + "/6", text_color=trend_score_bull >= 4 ? color.green : color.gray, text_size=size.small)
    table.cell(info, 0, 1, "Squeeze", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, squeeze_on ? "ON" : "OFF", text_color=squeeze_on ? color.red : color.green, text_size=size.small)
    table.cell(info, 0, 2, "Kelly Size", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(math.round(position_size, 1)) + "%", text_color=color.white, text_size=size.small)
    table.cell(info, 0, 3, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(math.round(momentum, 2)), text_color=momentum > 0 ? color.green : color.red, text_size=size.small)
    table.cell(info, 0, 4, "ADX", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(math.round(adx, 1)), text_color=adx > 20 ? color.green : color.gray, text_size=size.small)
