//@version=5
strategy("50_Ultimate_Alpha", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

// Most selective: EMA stack + Ichimoku + TK + PSAR + Supertrend + ADX>30 + OBV + DI — 7 of 8 must agree
sl_pct = input.float(1.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(5.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(0.5, "Trailing Stop %", step=0.1) / 100

// === INDICATORS ===
// 1. EMA Stack: ema8 > ema21 > ema50
ema8 = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
sig_stack = (ema8 > ema21 and ema21 > ema50) ? 1 : 0

// 2. Ichimoku above cloud
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
span_a = (tenkan + kijun) / 2
span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
sig_ichi = (close > span_a and close > span_b) ? 1 : 0

// 3. Tenkan > Kijun
sig_tk = tenkan > kijun ? 1 : 0

// 4. PSAR
psar = ta.sar(0.02, 0.02, 0.2)
sig_psar = close > psar ? 1 : 0

// 5. Supertrend
atr14 = ta.atr(14)
supertrend = (high + low) / 2 - 3 * atr14
sig_super = close > supertrend ? 1 : 0

// 6. ADX > 30 (strong trend only)
[diplus, diminus, adx_val] = ta.dmi(14, 14)
sig_adx = adx_val > 30 ? 1 : 0

// 7. OBV Rising
obv = ta.obv
obv_sma = ta.sma(obv, 20)
sig_obv = obv > obv_sma ? 1 : 0

// 8. DI+ > DI-
sig_di = diplus > diminus ? 1 : 0

// === 7 of 8 must agree for entry ===
total_signals = sig_stack + sig_ichi + sig_tk + sig_psar + sig_super + sig_adx + sig_obv + sig_di
long_entry = total_signals >= 7
exit_signal = total_signals < 4

// === EXECUTION ===
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message='{"strategy":"Ultimate_Alpha","symbol":"' + syminfo.ticker + '","side":"BUY","price":' + str.tostring(close) + ',"sl_pct":' + str.tostring(sl_pct) + ',"tp_pct":' + str.tostring(tp_pct) + ',"ts_pct":' + str.tostring(ts_pct) + ',"timeframe":"' + timeframe.period + '"}')

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks, alert_message='{"strategy":"Ultimate_Alpha","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message='{"strategy":"Ultimate_Alpha","symbol":"' + syminfo.ticker + '","side":"SELL","price":' + str.tostring(close) + ',"timeframe":"' + timeframe.period + '"}')

// === VISUALS ===
plot(ema8, "EMA8", color=color.blue)
plot(ema21, "EMA21", color=color.orange)
plot(ema50, "EMA50", color=color.purple)
plot(span_a, "Span A", color=color.green)
plot(span_b, "Span B", color=color.red)
plot(supertrend, "Supertrend", color=color.teal)
plotshape(psar, "PSAR", shape.cross, location.absolute, color=color.gray, size=size.tiny)
bgcolor(total_signals >= 7 ? color.new(color.green, 80) : total_signals >= 5 ? color.new(color.yellow, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
