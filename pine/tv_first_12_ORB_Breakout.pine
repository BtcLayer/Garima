//@version=5
// ORB BREAKOUT — Opening Range Breakout adapted for crypto 4h
// First 4h candle of the day defines the range. Break above = long, below = short.
// From AlgoEdge concept, adapted for crypto.
// Test on: BTCUSDT, ETHUSDT, SOLUSDT — 4h
strategy("ORB Breakout Crypto", overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(4.0, "TP %") / 100
adx_thresh = input.int(20, "ADX Threshold")

// ── OPENING RANGE (first 4h candle of UTC day) ──
is_new_day = ta.change(time("D")) != 0
var float or_high = na
var float or_low = na
var bool or_set = false

if is_new_day
    or_high := high
    or_low := low
    or_set := true
else if or_set and barstate.isconfirmed
    or_set := false  // lock range after first bar

// ── FILTERS ──
[diplus, diminus, adx] = ta.dmi(14, 14)
adx_ok = adx > adx_thresh
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// ── ENTRY: break above/below opening range ──
long_entry = not na(or_high) and close > or_high and close[1] <= or_high and adx_ok and vol_ok and vol_confirm
short_entry = not na(or_low) and close < or_low and close[1] >= or_low and adx_ok and vol_ok and vol_confirm

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int cooldown = 0
if is_new_day
    trades_today := 0
if cooldown > 0
    cooldown -= 1

was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        cooldown := 3

can_trade = trades_today < 2 and cooldown == 0

// ── EXECUTION ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_Exit", "Long", stop=close * (1 - sl_pct), limit=close * (1 + tp_pct))

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_Exit", "Short", stop=close * (1 + sl_pct), limit=close * (1 - tp_pct))

// Close at end of day
if is_new_day and strategy.position_size != 0
    strategy.close_all()

// ── VISUALS ──
plot(or_high, "OR High", color.green, 1, plot.style_stepline)
plot(or_low, "OR Low", color.red, 1, plot.style_stepline)
bgcolor(long_entry and can_trade ? color.new(color.green, 90) : short_entry and can_trade ? color.new(color.red, 90) : na)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
