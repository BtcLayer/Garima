//@version=5
strategy("23_Ichimoku_MACD_Pro", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95, commission_value=0.1)

sl_pct = input.float(2.0, "Stop Loss %", step=0.1) / 100
tp_pct = input.float(15.0, "Take Profit %", step=0.1) / 100
ts_pct = input.float(2.0, "Trailing Stop %", step=0.1) / 100
min_agreement = input.int(2, "Min Signals Required", minval=1, maxval=4)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Ichimoku_MACD_Pro","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Ichimoku_MACD_Pro","action":"CLOSE","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

tenkan_sen = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun_sen = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
senkou_span_a = (tenkan_sen + kijun_sen) / 2
senkou_span_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
sig_ichimoku = (close > senkou_span_a and close > senkou_span_b) ? 1 : 0

ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
macd_line = ema21 - ema50
signal_line = ta.ema(macd_line, 9)
sig_macd = (macd_line > signal_line and macd_line[1] <= signal_line[1]) ? 1 : 0

obv_val = ta.obv
obv_sma = ta.sma(obv_val, 20)
sig_obv = obv_val > obv_sma ? 1 : 0

vol_ma = ta.sma(volume, 20)
sig_volume = (volume > vol_ma * 1.5 and close > close[1]) ? 1 : 0

total_signals = sig_ichimoku + sig_macd + sig_obv + sig_volume
long_entry = total_signals >= min_agreement
exit_signal = total_signals < 1

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)

if strategy.position_size > 0
    trail_ticks = math.round(strategy.position_avg_price * ts_pct / syminfo.mintick)
    strategy.exit("SL/TP", "Long", stop=strategy.position_avg_price * (1 - sl_pct), limit=strategy.position_avg_price * (1 + tp_pct), trail_points=1, trail_offset=trail_ticks)

if exit_signal and strategy.position_size > 0
    strategy.close("Long", comment="Signal Exit", alert_message=close_alert)

plot(senkou_span_a, "Senkou A", color=color.green, style=plot.style_line)
plot(senkou_span_b, "Senkou B", color=color.red, style=plot.style_line)
bgcolor(total_signals >= min_agreement ? color.new(color.green, 90) : na)
plotshape(long_entry and strategy.position_size == 0, "Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
