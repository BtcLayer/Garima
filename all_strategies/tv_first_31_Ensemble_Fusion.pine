//@version=5
// ENSEMBLE FUSION — Combines Ichimoku + Engulfing + Momentum + Squeeze signals
// Each system "votes" — trade only when 2+ systems agree
// Individual strategies were WEAK alone, ensemble should filter noise
// Uses BB Squeeze V2's risk management (trailing stop, consecutive loss, circuit breaker)
// Test on: DOTUSDT, ETHUSDT, BTCUSDT, LDOUSDT — 4h
strategy("Ensemble Fusion", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100
min_votes = input.int(2, "Min Votes to Enter", minval=2, maxval=4)

// ═══════════════════════════════════════════
// SIGNAL 1: ICHIMOKU
// ═══════════════════════════════════════════
tenkan = (ta.highest(high, 9) + ta.lowest(low, 9)) / 2
kijun = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
senkou_a = (tenkan + kijun) / 2
senkou_b = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
cloud_top = math.max(senkou_a[26], senkou_b[26])
cloud_bot = math.min(senkou_a[26], senkou_b[26])

ichi_long = ta.crossover(tenkan, kijun) and close > cloud_top and senkou_a > senkou_b
ichi_short = ta.crossunder(tenkan, kijun) and close < cloud_bot and senkou_a < senkou_b

// ═══════════════════════════════════════════
// SIGNAL 2: ENGULFING + VOLUME
// ═══════════════════════════════════════════
body = math.abs(close - open)
body_prev = math.abs(close[1] - open[1])
vol_sma = ta.sma(volume, 20)

bull_engulf = close > open and close[1] < open[1] and open <= close[1] and close >= open[1] and body > body_prev and volume > vol_sma * 1.3
bear_engulf = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and body > body_prev and volume > vol_sma * 1.3

// ═══════════════════════════════════════════
// SIGNAL 3: MOMENTUM (ROC)
// ═══════════════════════════════════════════
roc = ta.roc(close, 12)
roc_val = ta.sma(roc, 3)
mom_long = roc_val > 0 and roc_val[1] <= 0 and roc_val > roc_val[1]
mom_short = roc_val < 0 and roc_val[1] >= 0 and roc_val < roc_val[1]

// ═══════════════════════════════════════════
// SIGNAL 4: BB SQUEEZE
// ═══════════════════════════════════════════
bb_basis = ta.sma(close, 20)
bb_dev = ta.stdev(close, 20) * 2.0
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
kc_basis = ta.ema(close, 20)
kc_range = ta.atr(20)
kc_upper = kc_basis + 1.5 * kc_range
kc_lower = kc_basis - 1.5 * kc_range
squeeze_on = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_release = not squeeze_on and squeeze_on[1]
hh = ta.highest(high, 20)
ll = ta.lowest(low, 20)
delta = close - math.avg(math.avg(hh, ll), bb_basis)
momentum = ta.linreg(delta, 20, 0)

sq_long = squeeze_release and momentum > 0
sq_short = squeeze_release and momentum < 0

// ═══════════════════════════════════════════
// VOTING SYSTEM
// ═══════════════════════════════════════════
long_votes = (ichi_long ? 1 : 0) + (bull_engulf ? 1 : 0) + (mom_long ? 1 : 0) + (sq_long ? 1 : 0)
short_votes = (ichi_short ? 1 : 0) + (bear_engulf ? 1 : 0) + (mom_short ? 1 : 0) + (sq_short ? 1 : 0)

// ── COMMON FILTERS ──
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
adx_ok = adx > 18

long_entry = long_votes >= min_votes and close > ema50 and vol_ok and adx_ok
short_entry = short_votes >= min_votes and close < ema50 and vol_ok and adx_ok

// ── MOMENTUM EXIT ──
rsi = ta.rsi(close, 14)
ema20 = ta.ema(close, 20)
long_exit = close < ema20 and rsi > 70
short_exit = close > ema20 and rsi < 30

// ── ANTI-OVERTRADING (BB Squeeze V2 style) ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION with TRAILING STOP ──
if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

// ── EXITS ──
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
vote_color = long_votes >= 2 ? color.new(color.green, 80) : short_votes >= 2 ? color.new(color.red, 80) : na
bgcolor(vote_color)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ENS")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="ENS")
