//@version=5
// CCI + KELTNER CHANNEL — CCI momentum breakout confirmed by Keltner channel position
strategy("G16 CCI Keltner Fusion [Webhook]", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_Keltner_Fusion","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_Keltner_Fusion","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_Keltner_Fusion","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_Keltner_Fusion","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

// ── INPUTS ──
cci_len    = input.int(20, "CCI Length")
kc_len     = input.int(20, "Keltner Length")
kc_mult    = input.float(1.5, "Keltner Multiplier")
sl_pct     = input.float(1.5, "SL %") / 100
tp_pct     = input.float(12.0, "TP %") / 100
trail_pct  = input.float(4.0, "Trail %") / 100

// ── CCI ──
cci = ta.cci(close, cci_len)
cci_cross_up = ta.crossover(cci, 100)
cci_cross_down = ta.crossunder(cci, -100)

// ── KELTNER CHANNEL ──
kc_basis = ta.ema(close, kc_len)
kc_atr = ta.atr(kc_len)
kc_upper = kc_basis + kc_mult * kc_atr
kc_lower = kc_basis - kc_mult * kc_atr
above_kc = close > kc_upper
below_kc = close < kc_lower

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// ── TIERED ENTRY ──
long_strong = cci_cross_up and above_kc and close > ema50 and adx > 25 and vol_confirm
long_medium = cci_cross_up and close > kc_basis and close > ema50 and adx > 18
short_strong = cci_cross_down and below_kc and close < ema50 and adx > 25 and vol_confirm
short_medium = cci_cross_down and close < kc_basis and close < ema50 and adx > 18

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = ta.crossunder(cci, 0) or close < kc_lower or rsi > 80
short_exit = ta.crossover(cci, 0) or close > kc_upper or rsi < 20

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(kc_upper, "KC Hi", color.green)
plot(kc_basis, "KC Mid", color.gray)
plot(kc_lower, "KC Lo", color.red)
