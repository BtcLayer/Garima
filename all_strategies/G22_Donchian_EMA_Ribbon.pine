//@version=5
// DONCHIAN + EMA RIBBON — Donchian breakout with EMA ribbon alignment (8/13/21/34/55)
// All EMAs stacked = strong trend, Donchian break = entry timing
strategy("G22 Donchian EMA Ribbon [Webhook]", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Donchian_EMA_Ribbon","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Donchian_EMA_Ribbon","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Donchian_EMA_Ribbon","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Donchian_EMA_Ribbon","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

// ── INPUTS ──
dc_len    = input.int(20, "Donchian Length")
dc_exit   = input.int(10, "Exit Channel Length")
sl_pct    = input.float(1.5, "SL %") / 100
tp_pct    = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// ── DONCHIAN ──
dc_upper = ta.highest(high, dc_len)
dc_lower = ta.lowest(low, dc_len)
exit_lower = ta.lowest(low, dc_exit)
exit_upper = ta.highest(high, dc_exit)
breakout_up = close > dc_upper[1]
breakout_down = close < dc_lower[1]

// ── EMA RIBBON ──
ema8  = ta.ema(close, 8)
ema13 = ta.ema(close, 13)
ema21 = ta.ema(close, 21)
ema34 = ta.ema(close, 34)
ema55 = ta.ema(close, 55)

bull_ribbon = ema8 > ema13 and ema13 > ema21 and ema21 > ema34 and ema34 > ema55
bear_ribbon = ema8 < ema13 and ema13 < ema21 and ema21 < ema34 and ema34 < ema55
partial_bull = ema8 > ema21 and ema21 > ema55
partial_bear = ema8 < ema21 and ema21 < ema55

// ── CONFIRMATION ──
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// ── TIERED ENTRY ──
long_strong = breakout_up and bull_ribbon and adx > 25 and vol_confirm
long_medium = breakout_up and partial_bull and adx > 20
short_strong = breakout_down and bear_ribbon and adx > 25 and vol_confirm
short_medium = breakout_down and partial_bear and adx > 20

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = close < exit_lower[1] or ta.crossunder(ema8, ema21) or rsi > 80
short_exit = close > exit_upper[1] or ta.crossover(ema8, ema21) or rsi < 20

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(ema8, "EMA8", color.lime)
plot(ema21, "EMA21", color.blue)
plot(ema55, "EMA55", color.red)
plot(dc_upper, "DC Hi", color.new(color.green, 70))
plot(dc_lower, "DC Lo", color.new(color.red, 70))
