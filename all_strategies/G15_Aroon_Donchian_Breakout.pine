//@version=5
// AROON + DONCHIAN BREAKOUT — Aroon confirms new trend + Donchian breakout timing
// Aroon Up > 70 = new highs forming, combined with Donchian channel break
strategy("G15 Aroon Donchian Breakout [Webhook]", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon_Donchian_Breakout","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon_Donchian_Breakout","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon_Donchian_Breakout","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon_Donchian_Breakout","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

// ── INPUTS ──
dc_len    = input.int(20, "Donchian Length")
dc_exit   = input.int(10, "Exit Channel Length")
aroon_len = input.int(14, "Aroon Length")
sl_pct    = input.float(1.5, "SL %") / 100
tp_pct    = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

// ── DONCHIAN ──
dc_upper = ta.highest(high, dc_len)
dc_lower = ta.lowest(low, dc_len)
exit_lower = ta.lowest(low, dc_exit)
exit_upper = ta.highest(high, dc_exit)
breakout_up = close > dc_upper[1]
breakout_down = close < dc_lower[1]

// ── AROON (manual — ta.aroon doesn't exist in Pine v5) ──
hi_bars = -ta.highestbars(high, aroon_len + 1)
lo_bars = -ta.lowestbars(low, aroon_len + 1)
aroon_up = 100.0 * (aroon_len - hi_bars) / aroon_len
aroon_down = 100.0 * (aroon_len - lo_bars) / aroon_len
aroon_bull = aroon_up > 70 and aroon_up > aroon_down
aroon_bear = aroon_down > 70 and aroon_down > aroon_up

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// ── TIERED ENTRY ──
long_strong = breakout_up and aroon_bull and close > ema50 and adx > 25 and vol_confirm
long_medium = breakout_up and aroon_up > 50 and close > ema50 and adx > 20
short_strong = breakout_down and aroon_bear and close < ema50 and adx > 25 and vol_confirm
short_medium = breakout_down and aroon_down > 50 and close < ema50 and adx > 20

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = close < exit_lower[1] or (aroon_down > aroon_up and aroon_down > 70) or rsi > 80
short_exit = close > exit_upper[1] or (aroon_up > aroon_down and aroon_up > 70) or rsi < 20

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(dc_upper, "DC Hi", color.green)
plot(dc_lower, "DC Lo", color.red)
plot(ema50, "EMA50", color.blue, 2)
