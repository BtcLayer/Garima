//@version=5
// BOLLINGER BAND MEAN REVERSION + VOLUME — Bollinger bands with volume
// Price touches lower band + volume spike = potential bounce
// Best for: BTC, ETH on 15m-1h (range-bound markets)
strategy("BB Mean Reversion Volume", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

bb_len = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Std Dev")
sl_pct = input.float(2.0, "SL %") / 100
tp_pct = input.float(10.0, "TP %") / 100
trail_pct = input.float(3.5, "Trail %") / 100

[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)

price_at_lower = close < bb_lower * 1.02
price_at_upper = close > bb_upper * 0.98

bounce_up = ta.crossover(close, bb_lower)
bounce_down = ta.crossunder(close, bb_upper)

[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)

vol_spike = volume > ta.sma(volume, 20) * 1.6
vol_normal = volume > ta.sma(volume, 20) * 1.2

ema50 = ta.ema(close, 50)

bb_width = (bb_upper - bb_lower) / bb_mid
squeeze = bb_width < ta.sma(bb_width, 20) * 0.7

long_entry = (price_at_lower or bounce_up) and vol_spike and rsi < 40 and rsi > 20 and adx < 30
short_entry = (price_at_upper or bounce_down) and vol_spike and rsi > 60 and rsi < 80 and adx < 30

long_exit = rsi > 65 or adx > 40 or close > bb_mid
short_exit = rsi < 35 or adx > 40 or close < bb_mid

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(bb_upper, "BB Upper", color.red, 1)
plot(bb_mid, "BB Mid", color.gray, 1)
plot(bb_lower, "BB Lower", color.green, 1)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="BBR")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="BBR")