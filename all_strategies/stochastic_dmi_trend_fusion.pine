//@version=5
// STOCHASTIC + DMI TREND FUSION — Stochastic with DMI trend confirmation
// Stochastic shows overbought/oversold, DMI confirms trend direction
// Best for: BTC, ETH on 1h-4h
strategy("Stochastic DMI Trend Fusion", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

stoch_k = input.int(14, "Stoch K")
stoch_d = input.int(3, "Stoch D")
stoch_slow = input.int(3, "Stoch Slow")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

stoch_k_val = ta.sma(ta.stoch(close, high, low, stoch_k), stoch_slow)
stoch_d_val = ta.sma(stoch_k_val, stoch_d)

stoch_cross_up = ta.crossover(stoch_k_val, stoch_d_val) and stoch_k_val < 40
stoch_cross_down = ta.crossunder(stoch_k_val, stoch_d_val) and stoch_k_val > 60

[diplus, diminus, adx] = ta.dmi(14, 14)
di_cross_up = ta.crossover(diplus, diminus)
di_cross_down = ta.crossunder(diplus, diminus)

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsi = ta.rsi(close, 14)

vol_confirm = volume > ta.sma(volume, 20) * 1.3

bullish_trend = ema50 > ema200 and close > ema50
bearish_trend = ema50 < ema200 and close < ema50

strong_long = stoch_cross_up and di_cross_up and adx > 20 and bullish_trend and vol_confirm
strong_short = stoch_cross_down and di_cross_down and adx > 20 and bearish_trend and vol_confirm

long_entry = strong_long or (stoch_cross_up and adx > 18 and rsi > 35 and rsi < 65 and bullish_trend)
short_entry = strong_short or (stoch_cross_down and adx > 18 and rsi > 35 and rsi < 65 and bearish_trend)

long_exit = stoch_cross_down or rsi > 75 or adx < 15
short_exit = stoch_cross_up or rsi < 25 or adx < 15

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="SDT")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="SDT")