//@version=5
// CCI + ADX POWER TREND — CCI breakout with strict ADX>30 power filter
// Only enters when trend is VERY strong, fewer trades but higher quality
strategy("G18 CCI ADX Power Trend [Webhook]", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"
long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_ADX_Power_Trend","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_ADX_Power_Trend","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_ADX_Power_Trend","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI_ADX_Power_Trend","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

// ── INPUTS ──
cci_len    = input.int(20, "CCI Length")
adx_power  = input.int(30, "ADX Power Threshold")
sl_pct     = input.float(1.5, "SL %") / 100
tp_pct     = input.float(12.0, "TP %") / 100
trail_pct  = input.float(4.0, "Trail %") / 100

// ── CCI ──
cci = ta.cci(close, cci_len)
cci_cross_up = ta.crossover(cci, 100)
cci_cross_down = ta.crossunder(cci, -100)
cci_strong_bull = cci > 150
cci_strong_bear = cci < -150

// ── ADX POWER ──
[diplus, diminus, adx] = ta.dmi(14, 14)
power_trend = adx > adx_power
di_bull = diplus > diminus
di_bear = diminus > diplus

// ── CONFIRMATION ──
ema50 = ta.ema(close, 50)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

// ── TIERED ENTRY ──
long_strong = cci_cross_up and power_trend and di_bull and close > ema50 and vol_confirm
long_medium = cci_cross_up and adx > 25 and di_bull and close > ema50
short_strong = cci_cross_down and power_trend and di_bear and close < ema50 and vol_confirm
short_medium = cci_cross_down and adx > 25 and di_bear and close < ema50

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── EXIT ──
long_exit = ta.crossunder(cci, 0) or (adx < 20) or rsi > 80
short_exit = ta.crossover(cci, 0) or (adx < 20) or rsi < 20

// ── ANTI-OVERTRADING ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="PWR")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="PWR")
