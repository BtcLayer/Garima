//@version=5
// MOMENTUM V2 — ROC + acceleration + BB Squeeze V2 risk management
// V1 was WEAK (DOT +87%) — no trailing stop, exits too rigid
// V2 adds: trailing stop, multi-timeframe momentum, consecutive loss tracking
// Test on: DOTUSDT, ETHUSDT, BTCUSDT, LDOUSDT — 4h
strategy("Momentum V2", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

// ── INPUTS ──
roc_len = input.int(12, "ROC Length")
roc_smooth = input.int(3, "ROC Smoothing")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(10.0, "TP %") / 100
trail_pct = input.float(3.5, "Trail %") / 100

// ── RATE OF CHANGE ──
roc = ta.roc(close, roc_len)
roc_val = ta.sma(roc, roc_smooth)
roc_accel = roc_val > roc_val[1]
roc_decel = roc_val < roc_val[1]

// ── MULTI-TIMEFRAME MOMENTUM (stronger confirmation) ──
roc_fast = ta.roc(close, 6)
roc_slow = ta.roc(close, 24)
momentum_aligned_bull = roc_fast > 0 and roc_slow > 0
momentum_aligned_bear = roc_fast < 0 and roc_slow < 0

// ── TREND ──
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

// ── TIERED ENTRY ──
// Strong: ROC crosses zero + accelerating + multi-TF aligned + volume
long_strong = roc_val > 0 and roc_val[1] <= 0 and roc_accel and momentum_aligned_bull and close > ema50 and adx > 25 and vol_confirm
short_strong = roc_val < 0 and roc_val[1] >= 0 and roc_decel and momentum_aligned_bear and close < ema50 and adx > 25 and vol_confirm

// Medium: ROC crosses zero + basic trend
long_medium = roc_val > 0 and roc_val[1] <= 0 and roc_accel and close > ema50 and adx > 20
short_medium = roc_val < 0 and roc_val[1] >= 0 and not roc_accel and close < ema50 and adx > 20

long_entry = long_strong or long_medium
short_entry = short_strong or short_medium

// ── MOMENTUM FADE EXIT ──
long_momentum_fade = roc_val < 0 or (rsi > 75 and roc_decel)
short_momentum_fade = roc_val > 0 or (rsi < 25 and roc_accel)

// ── ANTI-OVERTRADING (BB Squeeze V2 style) ──
var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

// ── EXECUTION with TRAILING STOP ──
if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)

// ── MOMENTUM REVERSAL EXIT ──
if long_momentum_fade and strategy.position_size > 0
    strategy.close("Long")
if short_momentum_fade and strategy.position_size < 0
    strategy.close("Short")

// ── VISUALS ──
plot(ema50, "EMA50", color.blue, 2)
plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small)
bgcolor(roc_val > 0 ? color.new(color.green, 95) : color.new(color.red, 95))
