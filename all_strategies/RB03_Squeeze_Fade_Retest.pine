//@version=5
// RB03 - Research-only range-bound strategy
// Fade the first squeeze expansion after an exhaustion move back toward the basis
strategy("RB03 Squeeze Fade Retest", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"

bb_len = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Mult")
kc_mult = input.float(1.5, "KC Mult")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(10.0, "TP %") / 100
trail_pct = input.float(2.5, "Trail %") / 100

long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"RB03 Squeeze Fade Retest","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"RB03 Squeeze Fade Retest","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"RB03 Squeeze Fade Retest","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"RB03 Squeeze Fade Retest","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

basis = ta.sma(close, bb_len)
dev = ta.stdev(close, bb_len) * bb_mult
upper = basis + dev
lower = basis - dev
kc_basis = ta.ema(close, bb_len)
kc_range = ta.atr(bb_len)
kc_upper = kc_basis + kc_mult * kc_range
kc_lower = kc_basis - kc_mult * kc_range
squeeze_on = upper < kc_upper and lower > kc_lower
squeeze_release = not squeeze_on and squeeze_on[1]

rsi = ta.rsi(close, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2

extended_up = close > upper and rsi > 66
extended_down = close < lower and rsi < 34
long_entry = squeeze_release and extended_down[1] and close > lower and close < basis
short_entry = squeeze_release and extended_up[1] and close < upper and close > basis

long_exit = close >= basis or rsi > 55
short_exit = close <= basis or rsi < 45

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(upper, "BB Upper", color.red)
plot(lower, "BB Lower", color.green)
plot(basis, "BB Basis", color.orange)
