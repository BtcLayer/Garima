//@version=5
// HULL MA CROSSOVER + VOLUME — Hull MA is smoother than EMA
// Fast and slow Hull MA crossover with volume confirmation
// Best for: All assets on 15m-4h
strategy("Hull MA Cross Volume", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

fast_len = input.int(9, "Fast Hull Length")
slow_len = input.int(21, "Slow Hull Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

hull(src, length) =>
    wma1 = ta.wma(src, math.round(length / 2))
    wma2 = ta.wma(src, length)
    2 * wma1 - wma2

hull_fast = hull(close, fast_len)
hull_slow = hull(close, slow_len)

hull_cross_up = ta.crossover(hull_fast, hull_slow)
hull_cross_down = ta.crossunder(hull_fast, hull_slow)

[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr = ta.atr(14)

vol_spike = volume > ta.sma(volume, 20) * 1.5
vol_normal = volume > ta.sma(volume, 20) * 1.2

ema50 = ta.ema(close, 50)

long_entry = hull_cross_up and adx > 20 and rsi > 30 and rsi < 70 and vol_normal
short_entry = hull_cross_down and adx > 20 and rsi > 30 and rsi < 70 and vol_normal

long_exit = hull_cross_down or rsi > 75 or adx < 15
short_exit = hull_cross_up or rsi < 25 or adx < 15

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(hull_fast, "Hull Fast", color.green, 2)
plot(hull_slow, "Hull Slow", color.red, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="HULL")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="HULL")