//@version=5
// AROON + DONCHIAN FUSION — trend acceleration plus breakout structure
// Aroon strength combined with Donchian breakout to avoid weak crosses
// Best for: LINK, AVAX, ETH, SOL, BNB on 4h
strategy("Aroon Donchian Fusion", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"

aroon_len = input.int(25, "Aroon Length")
don_len = input.int(20, "Donchian Length")
sl_pct = input.float(2.0, "SL %") / 100
tp_pct = input.float(14.0, "TP %") / 100
trail_pct = input.float(4.5, "Trail %") / 100

long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon Donchian Fusion","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon Donchian Fusion","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon Donchian Fusion","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"Aroon Donchian Fusion","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

aroon_up = 100 * (aroon_len - ta.highestbars(high, aroon_len)) / aroon_len
aroon_down = 100 * (aroon_len - ta.lowestbars(low, aroon_len)) / aroon_len
aroon_osc = aroon_up - aroon_down

don_upper = ta.highest(high, don_len)
don_lower = ta.lowest(low, don_len)

breakout_up = close > don_upper[1]
breakout_down = close < don_lower[1]
strong_bull = aroon_up > 70 and aroon_osc > 30
strong_bear = aroon_down > 70 and aroon_osc < -30

[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2

long_entry = breakout_up and strong_bull and close > ema50 and ema50 > ema200 and adx > 20 and rsi > 35 and rsi < 70 and vol_confirm
short_entry = breakout_down and strong_bear and close < ema50 and ema50 < ema200 and adx > 20 and rsi > 30 and rsi < 65 and vol_confirm

long_exit = ta.crossunder(aroon_up, aroon_down) or close < ema50 or rsi > 75
short_exit = ta.crossover(aroon_up, aroon_down) or close > ema50 or rsi < 25

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(aroon_up, "Aroon Up", color.green)
plot(aroon_down, "Aroon Down", color.red)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ADF")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="ADF")
