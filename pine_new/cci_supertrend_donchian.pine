//@version=5
// CCI + SUPERTREND + DONCHIAN — high-conviction three-signal fusion
// Donchian breakout plus CCI trend plus Supertrend confirmation
// Best for: ETH, BTC, LDO, DOT, AVAX on 4h
strategy("CCI Supertrend Donchian", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"

don_len = input.int(20, "Donchian Length")
cci_len = input.int(20, "CCI Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(14.0, "TP %") / 100
trail_pct = input.float(4.5, "Trail %") / 100

long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI Supertrend Donchian","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI Supertrend Donchian","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI Supertrend Donchian","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"CCI Supertrend Donchian","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

don_upper = ta.highest(high, don_len)
don_lower = ta.lowest(low, don_len)
cci = ta.cci(close, cci_len)
[st_val, st_dir] = ta.supertrend(3.0, 10)

don_bull = close > don_upper[1]
don_bear = close < don_lower[1]
cci_bull = cci > 100
cci_bear = cci < -100
st_bull = st_dir == -1
st_bear = st_dir == 1

[diplus, diminus, adx] = ta.dmi(14, 14)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

long_entry = don_bull and cci_bull and st_bull and close > ema50 and ema50 > ema200 and adx > 20 and vol_confirm
short_entry = don_bear and cci_bear and st_bear and close < ema50 and ema50 < ema200 and adx > 20 and vol_confirm

long_exit = st_bear or cci < 0 or rsi > 80
short_exit = st_bull or cci > 0 or rsi < 20

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(don_upper, "Don Upper", color.green)
plot(don_lower, "Don Lower", color.red)
plot(st_val, "Supertrend", color=st_dir == -1 ? color.lime : color.orange, linewidth=2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="CSD")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="CSD")
