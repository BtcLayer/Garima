//@version=5
// WILLIAMS %R + TREND FUSION — Williams %R with EMA trend filter
// Williams %R exits oversold/overbought with trend confirmation
// Best for: BTC, ETH, SOL on 15m-4h
strategy("Williams R Trend Fusion", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

wr_len = input.int(14, "Williams %R Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

wr = ta.wpr(wr_len)

wr_oversold = wr < -80
wr_overbought = wr > -20
wr_cross_up = ta.crossover(wr, -80)
wr_cross_down = ta.crossunder(wr, -20)

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
atr = ta.atr(14)

vol_ok = volume > ta.sma(volume, 20) * 1.2
vol_spike = volume > ta.sma(volume, 20) * 1.5

bullish_trend = ema20 > ema50 and ema50 > ema200
bearish_trend = ema20 < ema50 and ema50 < ema200

strong_long = wr_cross_up and adx > 22 and rsi > 35 and rsi < 65 and vol_ok and bullish_trend
strong_short = wr_cross_down and adx > 22 and rsi > 35 and rsi < 65 and vol_ok and bearish_trend

long_entry = strong_long or (wr_oversold and adx > 20 and rsi > 45 and bullish_trend and vol_spike)
short_entry = strong_short or (wr_overbought and adx > 20 and rsi < 55 and bearish_trend and vol_spike)

long_exit = wr > -20 or adx < 15 or rsi > 75
short_exit = wr < -80 or adx < 15 or rsi < 25

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(ema50, "EMA50", color.blue, 2)
plot(ema200, "EMA200", color.gray, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="WR")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="WR")