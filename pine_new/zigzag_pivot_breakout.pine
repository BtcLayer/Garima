//@version=5
// ZIGZAG PIVOT BREAKOUT — Price breaks pivot high/low with momentum
// Pivot points + volume confirmation + trend alignment
// Best for: High volatility assets (SOL, AVAX, LINK)
strategy("Zigzag Pivot Breakout", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

pivot_len = input.int(20, "Pivot Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(16.0, "TP %") / 100
trail_pct = input.float(5.0, "Trail %") / 100

pivot_high = ta.pivothigh(pivot_len, pivot_len)
pivot_low = ta.pivotlow(pivot_len, pivot_len)

pivot_break_up = close > pivot_high[1] and close > ta.sma(close, 20)
pivot_break_down = close < pivot_low[1] and close < ta.sma(close, 20)

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)

vol_confirm = volume > ta.sma(volume, 20) * 1.4

bullish_trend = ema50 > ema200
bearish_trend = ema50 < ema200

long_entry = pivot_break_up and adx > 20 and rsi > 40 and rsi < 70 and vol_confirm and bullish_trend
short_entry = pivot_break_down and adx > 20 and rsi > 30 and rsi < 60 and vol_confirm and bearish_trend

long_exit = rsi > 80 or adx < 15 or close < ema50
short_exit = rsi < 20 or adx < 15 or close > ema50

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(ema50, "EMA50", color.blue, 2)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ZIG")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="ZAG")