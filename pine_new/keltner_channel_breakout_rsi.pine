//@version=5
// KELTNER CHANNEL BREAKOUT + RSI — Keltner Channel with RSI filter
// Price breaks upper/lower Keltner band with RSI confirmation
// Best for: High volatility assets (SOL, AVAX, MATIC) on 15m-4h
strategy("Keltner Channel Breakout RSI", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

kc_len = input.int(20, "Keltner Length")
kc_mult = input.float(2.0, "Keltner Multiplier")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(14.0, "TP %") / 100
trail_pct = input.float(4.5, "Trail %") / 100

kc_mid = ta.ema(close, kc_len)
kc_upper = kc_mid + kc_mult * ta.atr(kc_len)
kc_lower = kc_mid - kc_mult * ta.atr(kc_len)

break_up = close > kc_upper and close[1] <= kc_upper[1]
break_down = close < kc_lower and close[1] >= kc_lower[1]

[diplus, diminus, adx] = ta.dmi(14, 14)
rsi = ta.rsi(close, 14)
rsi_ma = ta.sma(rsi, 14)

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

vol_spike = volume > ta.sma(volume, 20) * 1.4

bullish_trend = close > ema50 and ema50 > ema200
bearish_trend = close < ema50 and ema50 < ema200

long_entry = break_up and rsi > 40 and rsi < 75 and adx > 20 and vol_spike and bullish_trend
short_entry = break_down and rsi > 25 and rsi < 60 and adx > 20 and vol_spike and bearish_trend

long_exit = rsi > 80 or adx < 15 or close < kc_mid
short_exit = rsi < 20 or adx > 15 or close > kc_mid

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
    strategy.exit("L_X", "Long", stop=close*(1-sl_pct), limit=close*(1+tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if short_entry and can_trade and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)
    strategy.exit("S_X", "Short", stop=close*(1+sl_pct), limit=close*(1-tp_pct),
         trail_points=close*trail_pct/100/syminfo.mintick, trail_offset=close*trail_pct/100/syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long")
if short_exit and strategy.position_size < 0
    strategy.close("Short")

plot(kc_upper, "KC Upper", color.red, 1)
plot(kc_mid, "KC Mid", color.blue, 1)
plot(kc_lower, "KC Lower", color.green, 1)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="KCB")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="KCB")