//@version=5
// EMA RIBBON + DONCHIAN PULLBACK — aligned trend with breakout confirmation
// EMA ribbon alignment plus Donchian breakout after a pullback to the fast EMA
// Best for: ETH, SOL, AVAX, LINK, BTC on 4h
strategy("EMA Ribbon Donchian Pullback", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1)

WEBHOOK_SECRET = "squeeze_tradingview_cluster_2026_secure"

don_len = input.int(20, "Donchian Length")
sl_pct = input.float(1.5, "SL %") / 100
tp_pct = input.float(12.0, "TP %") / 100
trail_pct = input.float(4.0, "Trail %") / 100

long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"EMA Ribbon Donchian Pullback","action":"BUY","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"EMA Ribbon Donchian Pullback","action":"SELL","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_long_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"EMA Ribbon Donchian Pullback","action":"CLOSE_LONG","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'
close_short_alert = '{"secret":"' + WEBHOOK_SECRET + '","strategy":"EMA Ribbon Donchian Pullback","action":"CLOSE_SHORT","ticker":"{{ticker}}","interval":"{{interval}}","price":"{{close}}"}'

ema8 = ta.ema(close, 8)
ema13 = ta.ema(close, 13)
ema21 = ta.ema(close, 21)
ema34 = ta.ema(close, 34)
ema55 = ta.ema(close, 55)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

don_upper = ta.highest(high, don_len)
don_lower = ta.lowest(low, don_len)

bull_ribbon = ema8 > ema13 and ema13 > ema21 and ema21 > ema34 and ema34 > ema55
bear_ribbon = ema8 < ema13 and ema13 < ema21 and ema21 < ema34 and ema34 < ema55

pullback_long = bull_ribbon and low <= ema8 * 1.002 and close > ema8
pullback_short = bear_ribbon and high >= ema8 * 0.998 and close < ema8
breakout_long = close > don_upper[1]
breakout_short = close < don_lower[1]

[diplus, diminus, adx] = ta.dmi(14, 14)
atr14 = ta.atr(14)
atr_ma = ta.sma(atr14, 100)
vol_ok = atr14 < atr_ma * 2
vol_confirm = volume > ta.sma(volume, 20) * 1.2
rsi = ta.rsi(close, 14)

long_entry = pullback_long and breakout_long and close > ema50 and ema50 > ema200 and adx > 20 and vol_confirm
short_entry = pullback_short and breakout_short and close < ema50 and ema50 < ema200 and adx > 20 and vol_confirm

long_exit = close < ema21 or rsi > 80
short_exit = close > ema21 or rsi < 20

var int trades_today = 0
var int consec_losses = 0
var int cooldown = 0
var float day_equity = strategy.equity
is_new_day = ta.change(time("D")) != 0
if is_new_day
    trades_today := 0
    day_equity := strategy.equity
if cooldown > 0
    cooldown -= 1
was_closed = strategy.position_size[1] != 0 and strategy.position_size == 0
if was_closed
    trades_today += 1
    if strategy.netprofit < strategy.netprofit[1]
        consec_losses += 1
        if consec_losses >= 3
            cooldown := 6
            consec_losses := 0
    else
        consec_losses := 0
daily_pnl = (strategy.equity - day_equity) / day_equity
can_trade = trades_today < 3 and cooldown == 0 and daily_pnl > -0.03

if long_entry and can_trade and vol_ok and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, alert_message=long_alert)
    strategy.exit("L_X", "Long",
         stop=close * (1 - sl_pct),
         limit=close * (1 + tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if short_entry and can_trade and vol_ok and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, alert_message=short_alert)
    strategy.exit("S_X", "Short",
         stop=close * (1 + sl_pct),
         limit=close * (1 - tp_pct),
         trail_points=close * trail_pct / 100 / syminfo.mintick,
         trail_offset=close * trail_pct / 100 / syminfo.mintick)
if long_exit and strategy.position_size > 0
    strategy.close("Long", alert_message=close_long_alert)
if short_exit and strategy.position_size < 0
    strategy.close("Short", alert_message=close_short_alert)

plot(ema8, "EMA8", color.lime)
plot(ema21, "EMA21", color.yellow)
plot(ema55, "EMA55", color.red)
plotshape(long_entry and can_trade, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small, text="ERD")
plotshape(short_entry and can_trade, "Sell", shape.triangledown, location.abovebar, color.red, size=size.small, text="ERD")
